<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY - Login</title>
  <link rel="stylesheet" href="/css/paginas/login.css" />
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>

  <div class="login-container">

    <!-- ===== LADO IZQUIERDO ===== -->
    <div class="left">

      <!-- Manchas de color -->
      <div class="mancha azul num1"></div>
      <div class="mancha azul num2"></div>
      <div class="mancha azul num3"></div>
      <div class="mancha azul num4"></div>

      <!-- Tags flotantes -->
      <div class="subject-tag tag-math">📐 Matemáticas</div>
      <div class="subject-tag tag-sci">🔬 Ciencias</div>
      <div class="subject-tag tag-lit">📚 Literatura</div>
      <div class="subject-tag tag-hist">📜 Historia</div>
      
      

      <!-- Wrapper del card con borde animado -->
      <div class="card-wrapper" id="cardWrapper">

        <!-- SVG del borde animado -->
        <svg class="card-border-svg" id="borderSvg" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="borderGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%"   stop-color="#4af0e8" stop-opacity="0" />
              <stop offset="40%"  stop-color="#4a8df8" stop-opacity="1" />
              <stop offset="60%"  stop-color="#70eaff" stop-opacity="1" />
              <stop offset="100%" stop-color="#4af0e8" stop-opacity="0" />
            </linearGradient>
          </defs>
          <rect id="borderRect" x="3" y="3" rx="22" ry="22" />
        </svg>

        <!-- Card del formulario -->
        <div class="card">

          <% if (error && error.length > 0) { %>
            <div class="error-box"><%= error %></div>
          <% } %>
          <% if (info && info.length > 0) { %>
            <div class="info-box"><%= info %></div>
          <% } %>

          <!-- LOGIN -->
          <div id="login">

            <!-- Ícono decorativo -->
            <div class="card-logo">
              <div class="card-logo-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              </div>
            </div>

            <h2>Iniciar Sesión</h2>
            <p class="sub-heading">Bienvenido de vuelta a tu plataforma</p>

            <form class="formulario" method="POST" action="/auth/login">

              <!-- Correo -->
              <div class="input-group">
                <span class="icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="M2 7l10 7 10-7"/>
                  </svg>
                </span>
                <input
                  type="email"
                  name="correo"
                  id="correo"
                  placeholder=" "
                  required
                  autofocus
                  autocomplete="email"
                />
                <label for="correo">Correo electrónico</label>
              </div>

              <!-- Contraseña -->
              <div class="input-group">
                <span class="icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="5" y="11" width="14" height="10" rx="2"/>
                    <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
                  </svg>
                </span>
                <input
                  type="password"
                  name="contrasena"
                  id="pass"
                  placeholder=" "
                  required
                  autocomplete="current-password"
                />
                <label for="pass">Contraseña</label>
                <!-- Ojito mostrar/ocultar -->
                <button
                  type="button"
                  class="toggle-password"
                  onclick="
                    var p = document.getElementById('pass');
                    var isHidden = p.type === 'password';
                    p.type = isHidden ? 'text' : 'password';
                    this.querySelector('.eye-open').style.display  = isHidden ? 'none' : 'block';
                    this.querySelector('.eye-close').style.display = isHidden ? 'block' : 'none';
                  "
                  title="Mostrar / ocultar contraseña"
                >
                  <svg class="eye-open" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="eye-close" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:none">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                  </svg>
                </button>
              </div>

              <button type="submit" class="btn">Ingresar</button>
            </form>

            <div class="divider"><span>o</span></div>

            <button
              class="forgot-link"
              onclick="document.getElementById('login').style.display='none'; document.getElementById('recuperar').style.display='block'"
            >
              ¿Olvidaste tu contraseña?
            </button>
          </div>

          <!-- RECUPERAR CONTRASEÑA -->
          <div id="recuperar" style="display:none">
            <button
              class="back-btn"
              onclick="document.getElementById('recuperar').style.display='none'; document.getElementById('login').style.display='block'"
            >
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
              Volver
            </button>
            <h2>Recuperar acceso</h2>
            <p class="sub" style="margin-bottom:22px; font-size:0.84rem;">
              El director recibirá una notificación para restablecer tu contraseña.
            </p>
            <form method="POST" action="/auth/recuperar">
              <div class="input-group">
                <span class="icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="M2 7l10 7 10-7"/>
                  </svg>
                </span>
                <input
                  type="email"
                  name="correo"
                  id="correo-rec"
                  placeholder=" "
                  required
                />
                <label for="correo-rec">Correo registrado</label>
              </div>
              <button type="submit" class="btn">Enviar solicitud</button>
            </form>
          </div>

        </div><!-- /card -->
      </div><!-- /card-wrapper -->
    </div><!-- /left -->

    <!-- ===== LADO DERECHO (SLIDER) ===== -->
    <div class="right">
      <div class="slider">

        <div class="slide active">
          <img src="https://i.pinimg.com/736x/5d/28/db/5d28dbfbf05c7248d6a9e59bc2514bb9.jpg" alt="Slide 1">
          <div class="contenido">
            <h2>Potencia tu institución</h2>
            <p>Integra estudiantes, docentes y administración en un entorno que impulsa el crecimiento académico.</p>
          </div>
        </div>

        <div class="slide">
          <img src="https://i.pinimg.com/736x/63/15/45/631545adea07b4210f72e8c40c70e310.jpg" alt="Slide 2">
          <div class="contenido">
            <h2>Avanza con cada actividad</h2>
            <p>Convierte cada tarea en un paso hacia tu desarrollo académico.</p>
          </div>
        </div>

        <div class="slide">
          <img src="https://i.pinimg.com/webp/736x/22/5e/d6/225ed64777b68c6108f4894f3da7c662.webp" alt="Slide 3">
          <div class="contenido">
            <h2>Impulsa tu aprendizaje con IA</h2>
            <p>Herramientas inteligentes que potencian tu rendimiento.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Título central KLASSY -->
    <h1 class="titulo-central">KLASSY</h1>

  </div>

  <script src="/js/login.js"></script>
</body>
</html>

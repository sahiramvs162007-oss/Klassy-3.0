<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Actividades</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/paginas/actividades.css" />
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <!-- ─── ESTADO: Sin asignaciones ─────────────────────────────────────── -->
      <% if (bloques.length === 0) { %>
        <div class="estado-vacio">
          <i data-lucide="book-open"></i>
          <h3>Sin asignaciones activas</h3>
          <p>No tienes materias asignadas para el año <%= new Date().getFullYear() %>. Contacta al administrador.</p>
        </div>

      <!-- ─── ESTADO: Selección de materia (bloques) ──────────────────────── -->
      <% } else if (!materiaIdActiva) { %>
        <div class="cabecera-pagina">
          <div>
            <h1 class="cabecera-pagina__titulo">Mis Materias</h1>
            <p class="cabecera-pagina__subtitulo">Selecciona una materia para gestionar sus actividades</p>
          </div>
        </div>

        <% if (!periodoActivo) { %>
          <div class="alerta alerta--info">
            <i data-lucide="info"></i>
            <span>⚠ No hay un periodo académico activo. Puedes ver actividades existentes pero no crear nuevas.</span>
          </div>
        <% } %>

        <%/* ─── Clase adaptativa: 1 materia = horizontal; 2+ = vertical ─── */%>
        <div class="bloques-materias <%= bloques.length === 1 ? 'solo-una' : 'varias' %>">
          <% bloques.forEach((bloque, bIdx) => { %>
            <%
              const colores = ['bloque--azul','bloque--verde','bloque--morado','bloque--naranja','bloque--rojo'];
              const colorCls = colores[bIdx % colores.length];
              const soloUnGrado = bloque.grados.length === 1;

              // Agrupar grados por nivel — para el picker de dos pasos
              const gradosPorNivel = {};
              bloque.grados.forEach(g => {
                const n = g.grado.nivel;
                if (!gradosPorNivel[n]) gradosPorNivel[n] = [];
                gradosPorNivel[n].push(g);
              });
              const nivelesOrdenados = Object.keys(gradosPorNivel).map(Number).sort((a,b) => a-b);
              const mId = bloque.materia._id.toString().replace(/[^a-z0-9]/gi,'');

              // Detectar el nivel de cada grado para mostrarlo en el chip
              const nivelNombre = n => n <= 6 ? 'PRIMARIA' : 'SECUNDARIA';
            %>
            <div class="bloque-materia <%= colorCls %>">

              <%/* ── Panel de color: detalle de la materia ── */%>
              <div class="bloque-materia__cabecera">
                <div class="bloque-materia__icono">
                  <i data-lucide="book-open"></i>
                </div>
                <%/* En modo varias: wrap en .info para truncado */%>
                <% if (bloques.length > 1) { %>
                  <div class="bloque-materia__info">
                    <h3 class="bloque-materia__nombre"><%= bloque.materia.nombre %></h3>
                    <% if (bloque.materia.descripcion) { %>
                      <p class="bloque-materia__desc"><%= bloque.materia.descripcion %></p>
                    <% } %>
                  </div>
                <% } else { %>
                  <h3 class="bloque-materia__nombre"><%= bloque.materia.nombre %></h3>
                  <% if (bloque.materia.descripcion) { %>
                    <p class="bloque-materia__desc"><%= bloque.materia.descripcion %></p>
                  <% } %>
                <% } %>
              </div>

              <%/* ── Panel blanco: grados ── */%>
              <div class="bloque-materia__grados">

                <%/* Encabezado solo en modo 1 materia */%>
                <% if (bloques.length === 1) { %>
                  <div class="bloque-materia__grados-header">
                    <p class="bloque-materia__grados-title">Selecciona el Grado</p>
                    <p class="bloque-materia__grados-subtitle">Niveles curriculares disponibles para esta materia</p>
                  </div>
                <% } %>

                <% if (soloUnGrado) { %>
                  <%/* Un solo grado: barra directa */%>
                  <a
                    href="/actividades/docente?materiaId=<%= bloque.materia._id %>&gradoId=<%= bloque.grados[0].grado._id %>"
                    class="grado-picker-barra grado-picker-barra--unico"
                  >
                    <span class="grado-picker-barra__icono"><i data-lucide="graduation-cap"></i></span>
                    <span class="grado-picker-barra__nombre"><%= bloque.grados[0].grado.nombre %></span>
                    <span class="grado-picker-barra__nivel"><%= nivelNombre(bloque.grados[0].grado.nivel) %></span>
                    <span class="grado-picker-barra__arrow"><i data-lucide="arrow-right"></i></span>
                  </a>

                <% } else { %>
                  <%/* Múltiples grados: picker de dos pasos */%>
                  <div class="grado-picker-multi" id="picker-<%= mId %>">

                    <%/* Paso 1: chips de nivel — tarjetitas cuadradas */%>
                    <div class="grado-picker-multi__paso1" id="paso1-<%= mId %>">
                      <span class="grado-picker-multi__label">
                        <i data-lucide="layers"></i> Selecciona el grado
                      </span>
                      <div class="grado-picker-multi__niveles">
                        <% nivelesOrdenados.forEach(nivel => { %>
                          <button
                            type="button"
                            class="grado-nivel-chip"
                            onclick="mostrarSalones('<%= mId %>', <%= nivel %>)"
                          >
                            <% if (gradosPorNivel[nivel].length > 1) { %>
                              <span class="grado-nivel-chip__count"><%= gradosPorNivel[nivel].length %></span>
                            <% } %>
                            <i data-lucide="graduation-cap" class="chip-icon"></i>
                            <span class="grado-nivel-chip__num"><%= nivel %>°</span>
                            <span class="grado-nivel-chip__sub"><%= nivelNombre(nivel) %></span>
                          </button>
                        <% }) %>
                      </div>
                    </div>

                    <%/* Paso 2: salones (ocultos hasta elegir nivel) */%>
                    <% nivelesOrdenados.forEach(nivel => { %>
                      <div
                        class="grado-picker-multi__paso2"
                        id="salones-<%= mId %>-<%= nivel %>"
                        style="display:none"
                      >
                        <button
                          type="button"
                          class="grado-picker-multi__volver"
                          onclick="volverNiveles('<%= mId %>', <%= nivel %>)"
                        >
                          <i data-lucide="arrow-left"></i>
                          <span><%= nivel %>° — Elige el salón</span>
                        </button>
                        <div class="grado-picker-multi__salones">
                          <% gradosPorNivel[nivel].forEach(g => { %>
                            <a
                              href="/actividades/docente?materiaId=<%= bloque.materia._id %>&gradoId=<%= g.grado._id %>"
                              class="grado-salon-chip"
                            >
                              <i data-lucide="graduation-cap"></i>
                              <%= g.grado.nombre %>
                            </a>
                          <% }) %>
                        </div>
                      </div>
                    <% }) %>

                  </div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>

      <!-- ─── ESTADO: Lista de actividades para materia+grado ─────────────── -->
      <% } else { %>

        <!-- ── Cabecera de actividades: 3 filas ── -->
        <div class="act-doc-cabecera">

          <!-- Fila 1: Título de sección + back -->
          <div class="act-doc-cabecera__fila-titulo">
            <a href="/actividades/docente" class="btn-back act-doc-btn-back">
              <i data-lucide="arrow-left"></i> Mis materias
            </a>
            <h1 class="cabecera-pagina__titulo">Actividades</h1>
          </div>

          <!-- Fila 2: Nueva actividad -->
          <div class="act-doc-cabecera__fila2">
          <% if (periodoActivo) { %>
              <button class="btn btn--primario" onclick="abrirDrawerCrear()">
                <i data-lucide="plus"></i> Nueva actividad
              </button>
              <% } %>
          </div>

          <!-- Fila 3: acceso-cards (materia, grado, periodo) + toggle finalizadas -->
          <div class="act-doc-cabecera__fila-info">
            <div class="act-doc-accesos">
              <!-- Card materia — clase acceso-card pura -->
              <div class="acceso-card acceso-card--azul">
                <div class="tarjeta-stat__icono tarjeta-stat__icono--azul">
                  <i data-lucide="book-open"></i>
                </div>
                <div class="tarjeta-stat__datos">
                  <span class="tarjeta-stat__valor"><%= materiaSeleccionada?.nombre %></span>
                  <span class="tarjeta-stat__etiqueta">Materia</span>
                </div>
              </div>
              <!-- Card grado -->
              <div class="acceso-card acceso-card--verde">
                <div class="tarjeta-stat__icono tarjeta-stat__icono--verde">
                  <i data-lucide="graduation-cap"></i>
                </div>
                <div class="tarjeta-stat__datos">
                  <span class="tarjeta-stat__valor"><%= gradoSeleccionado?.nombre %></span>
                  <span class="tarjeta-stat__etiqueta">Grado</span>
                </div>
              </div>
              <!-- Card periodo -->
              <% if (periodoActivo) { %>
                <div class="acceso-card acceso-card--morado">
                  <div class="tarjeta-stat__icono tarjeta-stat__icono--morado">
                    <i data-lucide="calendar-check"></i>
                  </div>
                  <div class="tarjeta-stat__datos">
                    <span class="tarjeta-stat__valor">Periodo <%= periodoActivo.numero %></span>
                    <span class="tarjeta-stat__etiqueta">Activo</span>
                  </div>
                </div>
              <% } else { %>
                <div class="acceso-card acceso-card--naranja">
                  <div class="tarjeta-stat__icono tarjeta-stat__icono--naranja">
                    <i data-lucide="alert-triangle"></i>
                  </div>
                  <div class="tarjeta-stat__datos">
                    <span class="tarjeta-stat__valor">Sin periodo</span>
                    <span class="tarjeta-stat__etiqueta">Inactivo</span>
                  </div>
                </div>
              <% } %>
            </div>

            <!-- Segmented control Vigentes / Finalizadas -->
            <div class="act-seg" id="actSegControl" role="group" aria-label="Filtro de actividades">
              <!-- Píldora deslizante (posicionada por JS) -->
              <span class="act-seg__pill" id="actSegPill" aria-hidden="true"></span>
              <button
                class="act-seg__btn act-seg__btn--activo"
                id="act-seg-vigentes"
                onclick="activarSegDoc('vigentes')"
                type="button"
              >
                <i data-lucide="clipboard-list"></i>
                Vigentes
              </button>
              <button
                class="act-seg__btn"
                id="act-seg-finalizadas"
                onclick="activarSegDoc('finalizadas')"
                type="button"
              >
                <i data-lucide="clock-x"></i>
                Finalizadas
              </button>
            </div>
          </div>

        </div><!-- /act-doc-cabecera -->

        <!-- Lista de actividades -->
        <% if (actividades.length === 0) { %>
          <div class="estado-vacio">
            <i data-lucide="clipboard-list"></i>
            <h3>Sin actividades</h3>
            <p>No hay actividades publicadas en esta materia y grado.</p>
            <% if (periodoActivo) { %>
              <button class="btn btn--primario" onclick="abrirDrawerCrear()">
                <i data-lucide="plus"></i> Crear primera actividad
              </button>
            <% } %>
          </div>
        <% } else { %>
          <%
            const vigentes    = actividades.filter(a => new Date() <= a.fechaLimite);
            const finalizadas = actividades.filter(a => new Date() >  a.fechaLimite);
          %>

          <!-- Panel VIGENTES -->
          <div id="panel-doc-vigentes">
            <% if (vigentes.length === 0) { %>
              <div class="estado-vacio">
                <i data-lucide="check-circle-2" style="color:#22c55e;"></i>
                <h3>Todas finalizadas</h3>
                <p>No hay actividades vigentes. Usa el botón para ver las finalizadas.</p>
              </div>
            <% } else { %>
                <div class="act-cards-grid act-cards-grid--panel">
                  <%
                    const acolores = ['act-card--azul','act-card--verde','act-card--morado','act-card--naranja','act-card--rojo','act-card--cyan'];
                  %>
                  <% vigentes.forEach((act, aIdx) => { %>
                    <%
                      const vencida  = new Date() > act.fechaLimite;
                      const colorCls = acolores[aIdx % acolores.length];
                    %>
                    <div class="act-card <%= colorCls %> act-card--<%= vencida ? 'vencida' : 'activa' %>">

                      <div class="act-card__header">
                        <div class="act-card__header-left">
                          <div class="act-card__icono">
                            <% if (vencida) { %>
                              <i data-lucide="clock-x"></i>
                            <% } else { %>
                              <i data-lucide="clipboard-list"></i>
                            <% } %>
                          </div>
                          <div>
                            <h3 class="act-card__titulo">
                              <a href="/actividades/docente/<%= act._id %>"><%= act.titulo %></a>
                            </h3>
                            <% if (act.periodoId) { %>
                              <span class="act-card__periodo">Periodo <%= act.periodoId.numero %></span>
                            <% } %>
                          </div>
                        </div>
                        <!-- [NUEVO Claude] Badges de estado y opciones -->
                        <div style="display:flex;gap:4px;flex-wrap:wrap;align-items:center;">
                          <% if (!vencida) { %>
                            <span class="act-card__badge act-card__badge--abierta">Vigente</span>
                          <% } else { %>
                            <span class="act-card__badge act-card__badge--cerrada">Finalizada</span>
                          <% } %>
                          <% if (!act.permitirMultiplesEntregas) { %>
                            <span class="badge badge--azul" title="Solo una entrega por estudiante">1 entrega</span>
                          <% } %>
                          <% if (act.permitirEntregaTardia) { %>
                            <span class="badge badge--pendiente" title="Permite entrega tardía">Tardía OK</span>
                          <% } %>
                          <% if (act.excepciones?.length > 0) { %>
                            <span class="badge badge--azul"><%= act.excepciones.length %> excepción<%= act.excepciones.length !== 1 ? 'es' : '' %></span>
                          <% } %>
                        </div>
                      </div>

                      <% if (act.descripcion) { %>
                        <p class="act-card__desc">
                          <%= act.descripcion.substring(0, 110) + (act.descripcion.length > 110 ? '…' : '') %>
                        </p>
                      <% } %>

                      <div class="act-card__meta">
                        <!-- [NUEVO Claude] Fecha de inicio si existe -->
                        <% if (act.fechaInicio) { %>
                          <span class="act-card__meta-item">
                            <i data-lucide="calendar-check"></i>
                            Inicia: <%= new Date(act.fechaInicio).toLocaleString('es-CO', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                          </span>
                        <% } %>
                        <span class="act-card__meta-item">
                          <i data-lucide="calendar-clock"></i>
                          <%= new Date(act.fechaLimite).toLocaleString('es-CO', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                        </span>
                        <span class="act-card__meta-item">
                          <i data-lucide="paperclip"></i>
                          <%= act.archivos?.length || 0 %> arch.
                        </span>
                        <span class="act-card__meta-item">
                          <i data-lucide="message-square"></i>
                          <%= act.comentarios?.length || 0 %> com.
                        </span>
                      </div>

                      <div class="act-card__progreso">
                        <div class="act-card__progreso-barra">
                          <div class="act-card__progreso-relleno" style="width:<%= act._porcentaje %>%"></div>
                        </div>
                        <div class="act-card__progreso-info">
                          <span class="act-card__progreso-nums"><%= act._totalEntregas %>/<%= act._totalEst %> entregaron</span>
                          <span class="act-card__progreso-pct"><%= act._porcentaje %>%</span>
                        </div>
                      </div>

                      <div class="act-card__acciones">
                        <a href="/actividades/docente/<%= act._id %>" class="act-card__btn-ver">
                          <i data-lucide="eye"></i> Ver entregas
                        </a>
                        <div class="act-card__acciones-sec">
                          <% if (!vencida) { %>
                            <button class="btn-icono btn-icono--editar"
                              onclick="abrirDrawerEditar('<%= act._id %>', `<%= act.titulo.replace(/`/g,'\\`') %>`, `<%= (act.descripcion||'').replace(/`/g,'\\`') %>`, '<%= act.fechaInicio ? act.fechaInicio.toISOString().slice(0,16) : "" %>', '<%= act.fechaLimite.toISOString().slice(0,16) %>', <%= act.permitirMultiplesEntregas ? 'true' : 'false' %>, <%= act.permitirEntregaTardia ? 'true' : 'false' %>)"
                              title="Editar">
                              <i data-lucide="pencil"></i>
                            </button>
                          <% } %>
                          <form method="POST" action="/actividades/docente/<%= act._id %>?_method=DELETE&materiaId=<%= materiaIdActiva %>&gradoId=<%= gradoIdActivo %>"
                            onsubmit="return confirm('¿Eliminar la actividad «<%= act.titulo %>»? Se eliminarán todas las entregas.')"
                            style="display:inline">
                            <button type="submit" class="btn-icono btn-icono--eliminar" title="Eliminar">
                              <i data-lucide="trash-2"></i>
                            </button>
                          </form>
                        </div>
                      </div>

                    </div>
                  <% }) %>
                </div>
            <% } %>
          </div>

          <!-- Panel FINALIZADAS (oculto por defecto) -->
          <div id="panel-doc-finalizadas" style="display:none;">
            <% if (finalizadas.length === 0) { %>
              <div class="estado-vacio">
                <i data-lucide="inbox" style="color:#94a3b8;"></i>
                <h3>Ninguna finalizada aún</h3>
                <p>No hay actividades finalizadas todavía.</p>
              </div>
            <% } else { %>
                <div class="act-cards-grid act-cards-grid--panel">
                  <%
                    const acolores = ['act-card--azul','act-card--verde','act-card--morado','act-card--naranja','act-card--rojo','act-card--cyan'];
                  %>
                  <% finalizadas.forEach((act, aIdx) => { %>
                    <%
                      const vencida  = new Date() > act.fechaLimite;
                      const colorCls = acolores[aIdx % acolores.length];
                    %>
                    <div class="act-card <%= colorCls %> act-card--<%= vencida ? 'vencida' : 'activa' %>">

                      <div class="act-card__header">
                        <div class="act-card__header-left">
                          <div class="act-card__icono">
                            <% if (vencida) { %>
                              <i data-lucide="clock-x"></i>
                            <% } else { %>
                              <i data-lucide="clipboard-list"></i>
                            <% } %>
                          </div>
                          <div>
                            <h3 class="act-card__titulo">
                              <a href="/actividades/docente/<%= act._id %>"><%= act.titulo %></a>
                            </h3>
                            <% if (act.periodoId) { %>
                              <span class="act-card__periodo">Periodo <%= act.periodoId.numero %></span>
                            <% } %>
                          </div>
                        </div>
                        <% if (!vencida) { %>
                          <span class="act-card__badge act-card__badge--abierta">Vigente</span>
                        <% } else { %>
                          <span class="act-card__badge act-card__badge--cerrada">Finalizada</span>
                        <% } %>
                      </div>

                      <% if (act.descripcion) { %>
                        <p class="act-card__desc">
                          <%= act.descripcion.substring(0, 110) + (act.descripcion.length > 110 ? '…' : '') %>
                        </p>
                      <% } %>

                      <div class="act-card__meta">
                        <span class="act-card__meta-item">
                          <i data-lucide="calendar-clock"></i>
                          <%= new Date(act.fechaLimite).toLocaleString('es-CO', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                        </span>
                        <span class="act-card__meta-item">
                          <i data-lucide="paperclip"></i>
                          <%= act.archivos?.length || 0 %> arch.
                        </span>
                        <span class="act-card__meta-item">
                          <i data-lucide="message-square"></i>
                          <%= act.comentarios?.length || 0 %> com.
                        </span>
                      </div>

                      <div class="act-card__progreso">
                        <div class="act-card__progreso-barra ">
                          <div class="act-card__progreso-relleno" style="width:<%= act._porcentaje %>%"></div>
                        </div>
                        <div class="act-card__progreso-info ">
                          <span class="act-card__progreso-nums"><%= act._totalEntregas %>/<%= act._totalEst %> entregaron</span>
                          <span class="act-card__progreso-pct"><%= act._porcentaje %>%</span>
                        </div>
                      </div>

                      <div class="act-card__acciones">
                        <a href="/actividades/docente/<%= act._id %>" class="act-card__btn-ver">
                          <i data-lucide="eye"></i> Ver entregas
                        </a>
                        <div class="act-card__acciones-sec">
                          <form method="POST" action="/actividades/docente/<%= act._id %>?_method=DELETE&materiaId=<%= materiaIdActiva %>&gradoId=<%= gradoIdActivo %>"
                            onsubmit="return confirm('¿Eliminar la actividad «<%= act.titulo %>»? Se eliminarán todas las entregas.')"
                            style="display:inline">
                            <button type="submit" class="btn-icono btn-icono--eliminar" title="Eliminar">
                              <i data-lucide="trash-2"></i>
                            </button>
                          </form>
                        </div>
                      </div>

                    </div>
                  <% }) %>
                </div>
            <% } %>
          </div>

        <% } %>
      <% } %>

    </main>
  </div>

  <!-- ─── Drawer lateral ──────────────────────────────────────────────── -->
  <div class="drawer-overlay" id="drawerOverlay" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo" id="drawerTitulo">Nueva actividad</h2>
      <button class="drawer__cerrar" onclick="cerrarDrawer()"><i data-lucide="x"></i></button>
    </div>
    <div class="drawer__cuerpo" id="drawerCuerpo"></div>
  </div>

  <!-- ─── Template: Crear actividad ──────────────────────────────────── -->
  <template id="templateCrearActividad">
    <form method="POST" action="/actividades/docente" enctype="multipart/form-data" class="formulario-grupo">
      <input type="hidden" name="gradoId"   value="<%= gradoIdActivo %>"/>
      <input type="hidden" name="materiaId" value="<%= materiaIdActiva %>"/>

      <div class="campo">
        <label class="campo__etiqueta">Título de la actividad *</label>
        <input type="text" name="titulo" class="campo__entrada" required
          placeholder="Ej: Taller de Fracciones, Exposición oral..." />
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Descripción / Instrucciones</label>
        <textarea name="descripcion" class="campo__area" rows="5"
          placeholder="Describe las instrucciones, criterios de evaluación, recursos necesarios..."></textarea>
      </div>

      <!-- [NUEVO Claude] Fechas en dos columnas con fecha de inicio opcional -->
      <div class="formulario-2col">
        <div class="campo">
          <label class="campo__etiqueta">
            Fecha de inicio
            <span class="campo__ayuda">(dejar vacío = publicar ahora)</span>
          </label>
          <input type="datetime-local" name="fechaInicio" class="campo__entrada" />
        </div>
        <div class="campo">
          <label class="campo__etiqueta">Fecha y hora límite *</label>
          <input type="datetime-local" name="fechaLimite" class="campo__entrada" required />
        </div>
      </div>

      <!-- [NUEVO Claude] Opciones de entrega -->
      <div class="campo">
        <label class="campo__etiqueta">Opciones de entrega</label>
        <div class="checks-grupo">
          <label class="check-opcion">
            <input type="checkbox" name="permitirMultiplesEntregas" checked />
            <span class="check-opcion__box"></span>
            <span>Permitir múltiples entregas</span>
          </label>
          <label class="check-opcion">
            <input type="checkbox" name="permitirEntregaTardia" />
            <span class="check-opcion__box"></span>
            <span>Permitir entrega después del plazo</span>
          </label>
        </div>
      </div>

      <!-- [NUEVO Claude] Publicación en otros grados de la misma materia -->
      <% if (gradosMismaMateria && gradosMismaMateria.length > 0) { %>
        <div class="campo">
          <label class="campo__etiqueta">
            Publicar también en otros grados
            <span class="campo__ayuda">(misma materia)</span>
          </label>
          <div class="checks-grupo">
            <% gradosMismaMateria.forEach(g => { %>
              <label class="check-opcion">
                <input type="checkbox" name="gradosExtras" value="<%= g.grado._id %>" />
                <span class="check-opcion__box"></span>
                <span><%= g.grado.nombre %> (Nivel <%= g.grado.nivel %>)</span>
              </label>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="campo">
        <label class="campo__etiqueta">Archivos adjuntos</label>
        <div class="campo-archivos">
          <label class="campo-archivos__zona" for="archivosActividad">
            <i data-lucide="upload-cloud"></i>
            <span>Arrastra archivos o haz clic para seleccionar</span>
            <span class="campo-archivos__tipos">JPG · PDF · DOCX · PPTX · XLSX · MP3 · MP4 (máx. 50MB c/u)</span>
          </label>
          <input type="file" id="archivosActividad" name="archivos" multiple
            accept=".jpg,.jpeg,.png,.pdf,.docx,.doc,.pptx,.ppt,.xlsx,.xls,.mp3,.mp4"
            onchange="mostrarArchivosSeleccionados(this, 'listaArchivosActividad')"
            style="display:none"/>
        </div>
        <div id="listaArchivosActividad" class="lista-archivos-preview"></div>
      </div>

      <div class="drawer__pie">
        <button type="button" class="btn btn--secundario" onclick="cerrarDrawer()">Cancelar</button>
        <button type="submit" class="btn btn--primario">
          <i data-lucide="send"></i> Publicar actividad
        </button>
      </div>
    </form>
  </template>

  <!-- ─── Template: Editar actividad ─────────────────────────────────── -->
  <template id="templateEditarActividad">
    <form method="POST" action="" enctype="multipart/form-data" class="formulario-grupo" id="formEditarActividad">
      <input type="hidden" name="_method" value="PUT"/>

      <div class="campo">
        <label class="campo__etiqueta">Título *</label>
        <input type="text" name="titulo" id="editTitulo" class="campo__entrada" required />
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Descripción / Instrucciones</label>
        <textarea name="descripcion" id="editDesc" class="campo__area" rows="4"></textarea>
      </div>

      <!-- [NUEVO Claude] Fechas en dos columnas -->
      <div class="formulario-2col">
        <div class="campo">
          <label class="campo__etiqueta">Fecha de inicio</label>
          <input type="datetime-local" name="fechaInicio" id="editFechaInicio" class="campo__entrada" />
        </div>
        <div class="campo">
          <label class="campo__etiqueta">Nueva fecha límite *</label>
          <input type="datetime-local" name="fechaLimite" id="editFechaLimite" class="campo__entrada" required />
        </div>
      </div>

      <!-- [NUEVO Claude] Opciones de entrega al editar -->
      <div class="campo">
        <label class="campo__etiqueta">Opciones de entrega</label>
        <div class="checks-grupo">
          <label class="check-opcion">
            <input type="checkbox" name="permitirMultiplesEntregas" id="editMultiEntrega" />
            <span class="check-opcion__box"></span>
            <span>Permitir múltiples entregas</span>
          </label>
          <label class="check-opcion">
            <input type="checkbox" name="permitirEntregaTardia" id="editTardiaOk" />
            <span class="check-opcion__box"></span>
            <span>Permitir entrega después del plazo</span>
          </label>
          <label class="check-opcion check-opcion--peligro">
            <input type="checkbox" name="cerrarAhora" id="editCerrarAhora" />
            <span class="check-opcion__box check-opcion__box--peligro"></span>
            <span>Cerrar actividad ahora</span>
          </label>
        </div>
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Agregar más archivos</label>
        <div class="campo-archivos">
          <label class="campo-archivos__zona" for="archivosEditar">
            <i data-lucide="upload-cloud"></i>
            <span>Seleccionar archivos adicionales</span>
          </label>
          <input type="file" id="archivosEditar" name="archivos" multiple
            accept=".jpg,.jpeg,.png,.pdf,.docx,.doc,.pptx,.ppt,.xlsx,.xls,.mp3,.mp4"
            onchange="mostrarArchivosSeleccionados(this, 'listaArchivosEditar')"
            style="display:none"/>
        </div>
        <div id="listaArchivosEditar" class="lista-archivos-preview"></div>
      </div>

      <div class="drawer__pie">
        <button type="button" class="btn btn--secundario" onclick="cerrarDrawer()">Cancelar</button>
        <button type="submit" class="btn btn--primario">
          <i data-lucide="save"></i> Guardar cambios
        </button>
      </div>
    </form>
  </template>

  <script src="/js/drawer.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/actividades-docente.js"></script>
</body>
</html>

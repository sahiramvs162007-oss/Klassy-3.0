<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Mis Actividades</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/paginas/actividades.css" />
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <!-- Cabecera -->
      <div class="cabecera-pagina">
        <div class="actividades-header">
          <a href="/actividades/estudiante" class="btn-back">
            <i data-lucide="arrow-left"></i> Mis materias
          </a>
          <h1 class="cabecera-pagina__titulo">Mis Actividades</h1>
          <% if (matricula) { %>
            <p class="cabecera-pagina__subtitulo">
              <i data-lucide="graduation-cap" style="width:14px;height:14px;vertical-align:middle;"></i>
              <%= matricula.gradoId?.nombre %> — <%= new Date().getFullYear() %>
            </p>
          <% } %>
        </div>
      </div>

      <% if (!matricula) { %>
        <div class="estado-vacio">
          <i data-lucide="file-x"></i>
          <h3>Sin matrícula activa</h3>
          <p>No tienes matrícula activa para el año <%= new Date().getFullYear() %>. Contacta al director.</p>
        </div>

      <% } else if (!materiaIdActiva) { %>

        <!-- ── SELECCIÓN DE MATERIA ── -->
        <% if (bloques.length === 0) { %>
          <div class="estado-vacio">
            <i data-lucide="book-x"></i>
            <h3>Sin materias asignadas</h3>
            <p>Tu grado aún no tiene materias asignadas por los docentes.</p>
          </div>
        <% } else { %>
          <p class="texto-secundario texto-sm" style="margin-bottom:18px;">Selecciona una materia para ver sus actividades.</p>
          <div class="bloques-materias">
            <% const colores = ['materia-card--azul','materia-card--verde','materia-card--morado','materia-card--naranja','materia-card--rojo']; %>
            <% bloques.forEach(function(bloque, i) { %>
              <%
                var colorCls = colores[i % colores.length];
                var estiloFondo = '';
                if (bloque.fondoTipo === 'color' && bloque.fondoValor) {
                  estiloFondo = bloque.fondoValor;
                }
              %>
              <a
                href="/actividades/estudiante?materiaId=<%= bloque.materia._id %>"
                class="materia-card <%= estiloFondo ? '' : colorCls %>"
                <% if (estiloFondo) { %>style="background:<%= estiloFondo %>;"<% } %>
              >
                <div class="materia-card__body">
                  <div class="materia-card__icono-wrap">
                    <i data-lucide="book-open"></i>
                  </div>
                  <h3 class="materia-card__nombre"<% if (bloque.colorTitulo) { %> style="color:<%= bloque.colorTitulo %>;"<% } %>>
                    <%= bloque.materia.nombre %>
                  </h3>
                  <% if (bloque.materia.descripcion) { %>
                    <p class="materia-card__desc"><%= bloque.materia.descripcion %></p>
                  <% } %>
                  <% if (bloque.docente) { %>
                    <span class="materia-card__docente">
                      <i data-lucide="user"></i>
                      <%= bloque.docente.nombre %> <%= bloque.docente.apellido %>
                    </span>
                  <% } %>
                </div>
                <div class="materia-card__footer">
                  <span>Ver actividades</span>
                  <span class="materia-card__footer-cta">
                    <i data-lucide="arrow-right"></i>
                  </span>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>

      <% } else { %>

        <!-- ── ACTIVIDADES DE LA MATERIA ── -->
        <div class="busqueda-panel">
          <div class="actividades-header__tags">
            <span class="acceso-card acceso-card--morado"><i data-lucide="book-open"></i> <%= materiaSeleccionada?.nombre %></span>
            <span class="acceso-card acceso-card--azul"><i data-lucide="graduation-cap"></i> <%= matricula.gradoId?.nombre %></span>
          </div>
          <form method="GET" action="/actividades/estudiante" class="busqueda-panel__barra busqueda-panel__barra--morado" style="max-width:400px; ">
            <input type="hidden" name="materiaId" value="<%= materiaIdActiva %>" />
            <select name="filtroPeriodo" class="barra-filtros-est__select" onchange="this.form.submit()" style="width: 100%;">
              <option value="">Todos los periodos</option>
              <% periodos.forEach(function(p) { %>
                <option value="<%= p._id %>" <%= filtroPeriodo === p._id.toString() ? 'selected' : '' %>><%= p.nombre %></option>
              <% }); %>
            </select>
            <% if (filtroPeriodo) { %>
              <a href="/actividades/estudiante?materiaId=<%= materiaIdActiva %>" class="btn btn--secundario btn--sm">
                <i data-lucide="x"></i> Limpiar
              </a>
            <% } %>
          </form>
        </div>

        <% if (actividades.length === 0) { %>
          <div class="estado-vacio">
            <i data-lucide="clipboard-list"></i>
            <h3>Sin actividades</h3>
            <p>Tu docente aún no ha publicado actividades en esta materia.</p>
          </div>
        <% } else { %>

          <%
            var pendientes = [];
            var entregadas = [];
            actividades.forEach(function(act) {
              if (act._estaCalificada || act._tieneEntrega) {
                entregadas.push(act);
              } else {
                pendientes.push(act);
              }
            });
          %>

          <!-- ── Tabla con tabs ── -->
          <div class="actividades-tabla-wrap">

            <!-- Tabs header -->
            <div class="act-tabs" role="tablist">
              <button
                class="act-tab act-tab--activo"
                id="tab-pendientes"
                role="tab"
                aria-selected="true"
                aria-controls="panel-pendientes"
                onclick="cambiarTab('pendientes')"
              >
                <span class="act-tab__icono"><i data-lucide="clock"></i></span>
                Pendientes
                <span class="act-tab__badge" id="badge-pendientes"><%= pendientes.length %></span>
              </button>
              <button
                class="act-tab"
                id="tab-entregadas"
                role="tab"
                aria-selected="false"
                aria-controls="panel-entregadas"
                onclick="cambiarTab('entregadas')"
              >
                <span class="act-tab__icono"><i data-lucide="check-circle-2"></i></span>
                Entregadas
                <span class="act-tab__badge" id="badge-entregadas"><%= entregadas.length %></span>
              </button>
            </div>

            <!-- Panel PENDIENTES -->
            <div class="act-panel act-panel--visible" id="panel-pendientes" role="tabpanel">
              <% if (pendientes.length === 0) { %>
                <div class="act-vacio">
                  <i data-lucide="check-circle-2" style="color:#22c55e;"></i>
                  <p class="act-vacio__titulo">¡Al día!</p>
                  <p class="act-vacio__sub">No tienes actividades pendientes.</p>
                </div>
              <% } else { %>
                <div class="act-lista">
                  <% pendientes.forEach(function(act) { %>
                    <%
                      var vencida  = act._vencida;
                      var cerrada  = act._cerrada;
                      // FIX: prioridad cerrada > vencida > pendiente
                      var badgeCls, badgeLabel, iconoCls, iconoNombre;
                      if (cerrada) {
                        badgeCls    = 'badge--cerrada';
                        badgeLabel  = 'Cerrada';
                        iconoCls    = 'act-item__icono--vencida';
                        iconoNombre = 'lock';
                      } else if (vencida) {
                        badgeCls    = 'badge--inactivo';
                        badgeLabel  = 'Vencida';
                        iconoCls    = 'act-item__icono--vencida';
                        iconoNombre = 'alert-circle';
                      } else {
                        badgeCls    = 'badge--pendiente';
                        badgeLabel  = 'Pendiente';
                        iconoCls    = 'act-item__icono--pendiente';
                        iconoNombre = 'clock';
                      }
                    %>
                    <a href="/actividades/estudiante/<%= act._id %>" class="act-item">
                      <div class="act-item__icono <%= iconoCls %>">
                        <i data-lucide="<%= iconoNombre %>"></i>
                      </div>
                      <div class="act-item__contenido">
                        <span class="act-item__titulo"><%= act.titulo %></span>
                        <div class="act-item__meta">
                          <% if (act.docenteId) { %>
                            <span class="act-item__meta-item">
                              <i data-lucide="user"></i>
                              <%= act.docenteId.nombre %> <%= act.docenteId.apellido %>
                            </span>
                          <% } %>
                          <span class="act-item__meta-item <%= vencida ? 'act-item__meta-item--vencida' : '' %>">
                            <i data-lucide="calendar"></i>
                            <%= vencida ? 'Venció: ' : 'Límite: ' %><%= new Date(act.fechaLimite).toLocaleString('es-CO', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                          </span>
                          <!-- [NUEVO Claude] Indicadores de opciones -->
                          <% if (!act.permitirMultiplesEntregas) { %>
                            <span class="act-item__meta-item" style="font-size:0.72rem;">
                              <i data-lucide="alert-triangle" style="width:11px;height:11px;"></i> 1 entrega
                            </span>
                          <% } %>
                          <% if (act.permitirEntregaTardia && vencida) { %>
                            <span class="act-item__meta-item" style="font-size:0.72rem;color:var(--verde-600);">
                              <i data-lucide="check" style="width:11px;height:11px;"></i> Tardía OK
                            </span>
                          <% } %>
                        </div>
                      </div>
                      <div class="act-item__derecha">
                        <span class="badge <%= badgeCls %>"><%= badgeLabel %></span>
                      </div>
                      <div class="act-item__arrow"><i data-lucide="chevron-right"></i></div>
                    </a>
                  <% }); %>
                </div>
              <% } %>
            </div>

            <!-- Panel ENTREGADAS -->
            <div class="act-panel" id="panel-entregadas" role="tabpanel">
              <% if (entregadas.length === 0) { %>
                <div class="act-vacio">
                  <i data-lucide="inbox" style="color:#94a3b8;"></i>
                  <p class="act-vacio__titulo">Nada por aquí aún</p>
                  <p class="act-vacio__sub">Aún no has entregado ninguna actividad.</p>
                </div>
              <% } else { %>
                <div class="act-lista">
                  <% entregadas.forEach(function(act) { %>
                    <%
                      var calificada = act._estaCalificada;
                      var badgeCls   = calificada ? 'badge--activo' : 'badge--azul';
                      var badgeLabel = calificada ? 'Calificada' : 'Entregada';
                      var iconoCls   = calificada ? 'act-item__icono--calificada' : 'act-item__icono--entregada';
                      var iconoNombre = calificada ? 'star' : 'check-circle-2';
                    %>
                    <a href="/actividades/estudiante/<%= act._id %>" class="act-item">
                      <div class="act-item__icono <%= iconoCls %>">
                        <i data-lucide="<%= iconoNombre %>"></i>
                      </div>
                      <div class="act-item__contenido">
                        <span class="act-item__titulo"><%= act.titulo %></span>
                        <div class="act-item__meta">
                          <% if (act.docenteId) { %>
                            <span class="act-item__meta-item">
                              <i data-lucide="user"></i>
                              <%= act.docenteId.nombre %> <%= act.docenteId.apellido %>
                            </span>
                          <% } %>
                          <span class="act-item__meta-item">
                            <i data-lucide="calendar"></i>
                            <%= new Date(act.fechaLimite).toLocaleString('es-CO', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                          </span>
                        </div>
                      </div>
                      <div class="act-item__derecha">
                        <span class="badge <%= badgeCls %>"><%= badgeLabel %></span>
                        <% if (calificada && act._mejorNota > 0) { %>
                          <span class="act-item__nota act-item__nota--<%= act._mejorNota >= 3 ? 'ok' : 'mal' %>">
                            <i data-lucide="star" style="width:10px;height:10px;"></i>
                            <%= act._mejorNota.toFixed(1) %>
                          </span>
                        <% } %>
                      </div>
                      <div class="act-item__arrow"><i data-lucide="chevron-right"></i></div>
                    </a>
                  <% }); %>
                </div>
              <% } %>
            </div>

          </div><!-- /actividades-tabla-wrap -->

        <% } %>

      <% } %>

    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/actividades-estudiante.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Mis Notas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/paginas/notas.css" />
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <!-- Cabecera -->
      <div class="cabecera-pagina">
        <div>
          <h1 class="cabecera-pagina__titulo">Mis Notas</h1>
          <% if (matricula) { %>
            <p class="cabecera-pagina__subtitulo">
              <%= matricula.gradoId?.nombre %> — <%= new Date().getFullYear() %>
            </p>
          <% } %>
        </div>
      </div>

      <% if (!matricula) { %>
        <div class="estado-vacio">
          <i data-lucide="file-x"></i>
          <h3>Sin matrícula activa</h3>
          <p>No tienes matrícula activa para este año. Contacta al director.</p>
        </div>
      <% } else { %>

        <!-- Selector de periodo -->
        <form method="GET" action="/notas/estudiante" class="barra-filtros">
          <div class="barra-filtros__grupo">
            <select name="periodoId" class="campo__select barra-filtros__select" onchange="this.form.submit()">
              <option value="">Seleccionar periodo</option>
              <% periodos.forEach(p => { %>
                <option value="<%= p._id %>" <%= periodoIdActivo === p._id?.toString() ? 'selected' : '' %>>
                  <%= p.nombre %> <%= !p.activo ? '(Cerrado)' : '(Activo)' %>
                </option>
              <% }) %>
            </select>
          </div>
        </form>

        <% if (!periodoIdActivo) { %>
          <div class="estado-vacio">
            <i data-lucide="calendar"></i>
            <h3>Selecciona un periodo</h3>
            <p>Elige el periodo académico para ver tus notas.</p>
          </div>

        <% } else if (seccionesMaterias.length === 0) { %>
          <div class="estado-vacio">
            <i data-lucide="bar-chart-2"></i>
            <h3>Sin notas registradas</h3>
            <p>Aún no tienes calificaciones en este periodo.</p>
          </div>

        <% } else { %>

          <%
            // Promedio general del periodo
            const promsConValor = seccionesMaterias.filter(s => s.promedio !== null);
            const promGeneral = promsConValor.length
              ? (promsConValor.reduce((acc, s) => acc + s.promedio, 0) / promsConValor.length).toFixed(2)
              : null;
            const aprobadoGeneral = promGeneral !== null && parseFloat(promGeneral) >= 3.0;
          %>

          <!-- Tarjeta de resumen general -->
          <div class="tarjeta notas-resumen-est">
            <div class="notas-resumen-est__prom">
              <span class="notas-resumen-est__num <%= aprobadoGeneral ? 'notas-resumen-est__num--ok' : 'notas-resumen-est__num--mal' %>">
                <%= promGeneral || '—' %>
              </span>
              <span class="notas-resumen-est__label">Promedio general</span>
            </div>
            <div class="notas-resumen-est__stats">
              <div class="notas-resumen-est__stat">
                <span class="notas-resumen-est__stat-num"><%= seccionesMaterias.length %></span>
                <span class="notas-resumen-est__stat-label">Materias</span>
              </div>
              <div class="notas-resumen-est__stat">
                <span class="notas-resumen-est__stat-num">
                  <%= seccionesMaterias.filter(s => s.aprobada).length %>
                </span>
                <span class="notas-resumen-est__stat-label">Aprobadas</span>
              </div>
              <div class="notas-resumen-est__stat">
                <span class="notas-resumen-est__stat-num">
                  <%= seccionesMaterias.filter(s => !s.aprobada && s.promedio !== null).length %>
                </span>
                <span class="notas-resumen-est__stat-label">En riesgo</span>
              </div>
            </div>
          </div>

          <!-- Secciones por materia -->
          <div class="notas-materias-lista">
            <% seccionesMaterias.forEach(sec => { %>
              <div class="tarjeta notas-materia-seccion">
                <!-- Cabecera de la materia -->
                <div class="notas-materia-cabecera">
                  <div class="notas-materia-cabecera__info">
                    <div class="item-icono__circulo item-icono__circulo--azul">
                      <i data-lucide="book-open"></i>
                    </div>
                    <div>
                      <h3 class="notas-materia-cabecera__nombre"><%= sec.materia.nombre %></h3>
                      <% if (sec.docente) { %>
                        <span class="notas-materia-cabecera__docente">
                          <i data-lucide="user" style="width:12px;height:12px;"></i>
                          <%= sec.docente.nombre %> <%= sec.docente.apellido %>
                        </span>
                      <% } %>
                    </div>
                  </div>
                  <div class="notas-materia-cabecera__prom">
                    <span class="nota-promedio nota-promedio--<%= sec.aprobada ? 'ok' : (sec.promedio !== null ? 'mal' : 'neutro') %> nota-promedio--grande">
                      <%= sec.promedio !== null ? sec.promedio.toFixed(2) : '—' %>
                    </span>
                    <% if (sec.promedio !== null) { %>
                      <span class="badge <%= sec.aprobada ? 'badge--activo' : 'badge--error' %>">
                        <%= sec.aprobada ? 'Aprobada' : 'En riesgo' %>
                      </span>
                    <% } %>
                  </div>
                </div>

                <!-- Tabla de notas de la materia -->
                <% if (sec.notas.length > 0) { %>
                  <div class="notas-tabla-est">
                    <table class="tabla">
                      <thead>
                        <tr>
                          <th>Actividad</th>
                          <th>Nota</th>
                          <th>Estado</th>
                          <th>Comentario docente</th>
                          <th>Fecha</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% sec.notas.forEach(nota => { %>
                          <tr>
                            <td>
                              <a href="/actividades/estudiante/<%= nota.actividadId?._id %>" class="enlace-actividad">
                                <%= nota.actividadId?.titulo || '—' %>
                              </a>
                            </td>
                            <td>
                              <span class="nota-valor nota-valor--<%= nota.valor >= 3 ? 'ok' : 'mal' %>">
                                <%= nota.valor.toFixed(1) %>
                              </span>
                            </td>
                            <td>
                              <span class="badge <%= nota.valor >= 3 ? 'badge--activo' : 'badge--error' %>">
                                <%= nota.valor >= 3 ? 'Aprobada' : 'Reprobada' %>
                              </span>
                            </td>
                            <td class="texto-secundario texto-sm">
                              <%= nota.comentarioDocente || '—' %>
                            </td>
                            <td class="texto-secundario texto-sm">
                              <%= new Date(nota.createdAt).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) %>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <p class="texto-vacio" style="padding:12px 0;">Sin notas registradas en esta materia.</p>
                <% } %>

              </div>
            <% }) %>
          </div>

        <% } %>
      <% } %>

    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>

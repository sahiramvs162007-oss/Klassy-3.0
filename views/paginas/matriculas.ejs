<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Matrículas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/componentes/busqueda-panel.css">

  
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash messages -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>
      <% if (mensajeInfo && mensajeInfo.length > 0) { %>
        <div class="alerta alerta--info"><i data-lucide="info"></i><span><%= mensajeInfo %></span></div>
      <% } %>

      <!-- Cabecera -->
      <div class="cabecera-pagina">
        <div>
          <h1 class="cabecera-pagina__titulo">Gestión de Matrículas</h1>
        </div>
        <div class="cabecera-pagina__acciones">
          <% if (puedeMasiva) { %>
            <form method="POST" action="/matriculas/masiva" style="display:inline"
              onsubmit="return confirm('¿Ejecutar matrícula masiva para <%= añoActual + 1 %>? Se promoverán automáticamente todos los estudiantes según sus resultados del año actual.')">
              <button type="submit" class="btn btn--secundario">
                <i data-lucide="users"></i> Matrícula Masiva <%= añoActual + 1 %>
              </button>
            </form>
          <% } %>
          <button class="btn btn--primario" onclick="abrirDrawerCrearMatricula()">
            <i data-lucide="user-check"></i> Nueva matrícula
          </button>
        </div>
      </div>

      <!-- Filtros -->
      <div class="busqueda-panel">
        <div class="acceso-card acceso-card--naranja"><div class="tarjeta-stat__icono tarjeta-stat__icono--naranja"><i data-lucide="file-text"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= matriculas.length %></span><span class="tarjeta-stat__etiqueta">Matrículas</span></div></div>
        <form method="GET" action="/matriculas" class="busqueda-panel__barra busqueda-panel__barra--naranja" id="formFiltrosMatriculas">

          <!-- Hidden para el grado seleccionado -->
          <input type="hidden" name="filtroGrado" id="inputFiltroGrado" value="<%= filtroGrado %>" />

          <!-- Fila superior: búsqueda + año + estado + acciones -->
          <div class="barra-filtros__fila-superior">

            <div class="busqueda-panel__campo">
              <i data-lucide="search" class="barra-filtros__icono-buscar"></i>
              <input type="text" name="buscar" value="<%= buscar %>"
                placeholder="Buscar estudiante..." class="barra-filtros__entrada" />
            </div>

            <!-- Año -->
            <i data-lucide="calendar" class="barra-filtros__anio-icono"></i>
            <span class="barra-filtros__anio-label">Año</span>
            <div class="barra-filtros__anio-wrap">
              <select name="filtroAnio" id="selectAnioMatriculas" class="barra-filtros__anio-select" onchange="this.form.submit()">
                <option value="">Todos</option>
                <% años.forEach(a => { %>
                  <option value="<%= a %>" <%= filtroAnio == a ? 'selected' : '' %>><%= a %></option>
                <% }) %>
              </select>
            </div>

            <!-- Estado -->
            <div class="barra-filtros__anio-wrap">
              <select name="filtroEstado" class="barra-filtros__anio-select" onchange="this.form.submit()">
                <option value="">Todos los estados</option>
                <option value="activa"     <%= filtroEstado === 'activa'     ? 'selected' : '' %>>Activa</option>
                <option value="suspendida" <%= filtroEstado === 'suspendida' ? 'selected' : '' %>>Suspendida</option>
                <option value="inactiva"   <%= filtroEstado === 'inactiva'   ? 'selected' : '' %>>Inactiva</option>
                <option value="graduado"   <%= filtroEstado === 'graduado'   ? 'selected' : '' %>>Graduado</option>
              </select>
            </div>

            <div class="barra-filtros__acciones">
              <button type="submit" class="btn btn--primario btn--sm">
                <i data-lucide="search"></i> Buscar
              </button>
              <% if (buscar || filtroGrado || filtroEstado || filtroAnio) { %>
                <a href="/matriculas" class="btn btn--secundario btn--sm">
                  <i data-lucide="x"></i> Limpiar
                </a>
              <% } %>
            </div>
          </div>

          <!-- ── Filtro de grado (delegado a grado-picker.js) ───────── -->
          <div class="filtro-nivel-wrap">
            <button type="button" class="filtro-nivel_edu" id="btnFiltroGradoMatriculas">
              <i data-lucide="book-open"></i>
              <span>Grado</span>
              <% if (filtroGrado) {
                   const gradoSel = grados.find(g => g._id.toString() === filtroGrado);
                   if (gradoSel) { %>
                <span class="filtro-nivel__badge-trigger"><%= gradoSel.nombre %></span>
              <% }} %>
              <i data-lucide="chevron-down" class="filtro-nivel__chevron"></i>
            </button>
            <div class="filtro-nivel__panel" id="panelFiltroGradoMatriculas"></div>
          </div>

        </form>
      </div>

      <!-- Tabla -->
      <div class="tabla-contenedor tabla-container">
        <% if (matriculas.length === 0) { %>
          <div class="tabla-vacia">
            <i data-lucide="file-text"></i>
            <p>No se encontraron matrículas.</p>
            <button class="btn btn--primario btn--sm" onclick="abrirDrawerCrearMatricula()">
              Crear primera matrícula
            </button>
          </div>
        <% } else { %>
          <table class="tabla">
            <thead>
              <tr>
                <th>Estudiante</th>
                <th>Grado</th>
                <th>Nivel</th>
                <th>Año</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbodyMatriculas">
              <% matriculas.forEach(m => { %>
                <%
                  const nombreEstudiante = m.estudianteId
                    ? `${m.estudianteId.nombre} ${m.estudianteId.apellido}`
                    : 'Estudiante eliminado';
                  const nombreGrado = m.gradoId ? m.gradoId.nombre : '—';
                  const nivelGrado  = m.gradoId ? m.gradoId.nivel  : '—';

                  const clasesEstado = {
                    activa:     'badge--activo',
                    suspendida: 'badge--suspendido',
                    inactiva:   'badge--inactivo',
                    graduado:   'badge--morado',
                  };

                  const clasesTipo = {
                    nuevaMatricula:     'badge--azul',
                    matriculaRenovada:  'badge--verde',
                  };

                  const etiquetaTipo = {
                    nuevaMatricula:    'Nueva',
                    matriculaRenovada: 'Renovada',
                  };
                %>
                <tr>
                  <!-- Estudiante -->
                  <td>
                    <div class="usuario-celda">
                      <div class="usuario-celda__avatar usuario-celda__avatar--estudiante">
                        <%= m.estudianteId ? m.estudianteId.nombre.charAt(0).toUpperCase() + m.estudianteId.apellido.charAt(0).toUpperCase() : '??' %>
                      </div>
                      <div>
                        <span class="usuario-celda__nombre"><%= nombreEstudiante %></span>
                        <% if (m.estudianteId) { %>
                          <span class="texto-secundario texto-sm"><%= m.estudianteId.correo %></span>
                        <% } %>
                      </div>
                    </div>
                  </td>

                  <!-- Grado -->
                  <td class="texto-secundario"><%= nombreGrado %></td>

                  <!-- Nivel -->
                  <td><span class="badge badge--azul">Nivel <%= nivelGrado %></span></td>

                  <!-- Año -->
                  <td class="texto-secundario"><%= m.año %></td>

                  <!-- Tipo -->
                  <td>
                    <span class="badge <%= clasesTipo[m.tipo] || 'badge--inactivo' %>">
                      <%= etiquetaTipo[m.tipo] || m.tipo %>
                    </span>
                  </td>

                  <!-- Estado -->
                  <td>
                    <span class="badge <%= clasesEstado[m.estado] || 'badge--inactivo' %>">
                      <%= m.estado.charAt(0).toUpperCase() + m.estado.slice(1) %>
                    </span>
                  </td>

                  <!-- Acciones -->
                  <td>
                    <div class="acciones-tabla">
                      <!-- Ver detalle + historial -->
                      <button
                        class="btn-icono btn-icono--ver"
                        onclick="abrirDrawerDetalle('<%= m._id %>')"
                        title="Ver detalle e historial"
                      >
                        <i data-lucide="eye"></i>
                      </button>

                      <!-- Editar estado/observaciones -->
                      <button
                        class="btn-icono btn-icono--editar"
                        onclick="abrirDrawerEditarMatricula('<%= m._id %>', '<%= m.estado %>', `<%= (m.observaciones || '').replace(/`/g, '\\`') %>`)"
                        title="Editar matrícula"
                      >
                        <i data-lucide="pencil"></i>
                      </button>

                      <!-- Eliminar -->
                      <form method="POST" action="/matriculas/<%= m._id %>?_method=DELETE"
                        onsubmit="return confirm('¿Eliminar la matrícula de <%= nombreEstudiante %>?')"
                        style="display:inline">
                        <button type="submit" class="btn-icono btn-icono--eliminar" title="Eliminar">
                          <i data-lucide="trash-2"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

    </main>
  </div>

  <!-- ─── Drawer ─────────────────────────────────────────────────────────── -->
  <div class="drawer-overlay" id="drawerOverlay" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo" id="drawerTitulo">Nueva matrícula</h2>
      <button class="drawer__cerrar" onclick="cerrarDrawer()"><i data-lucide="x"></i></button>
    </div>
    <div class="drawer__cuerpo" id="drawerCuerpo"></div>
  </div>

  <!-- ─── Template: Crear matrícula ─────────────────────────────────────── -->
  <template id="templateCrearMatricula">
    <form id="formCrearMatricula" method="POST" action="/matriculas" class="formulario-grupo">

      <!-- Selector de año -->
      <div class="campo">
        <label class="campo__etiqueta">Año académico *</label>
        <input type="number" name="año" id="campoAnioMatricula" class="campo__entrada"
          required min="2000" max="2100" />
        <span class="campo__ayuda">
          Al cambiar el año se actualizan los estudiantes y grados disponibles.
        </span>
      </div>

      <!-- Selector de estudiante (picker dinámico) -->
      <div class="campo">
        <label class="campo__etiqueta">Estudiante *</label>
        <input type="hidden" name="estudianteId" id="campoEstudianteMatricula" required />
        <div class="est-picker-wrap" id="estPickerMat">
          <button type="button" class="est-picker__trigger" id="estPickerMatTrigger">
            <span class="est-picker__avatar-mini" id="estPickerMatAvatarMini" style="display:none;"></span>
            <span id="estPickerMatLabel" style="color:var(--gris-400);">Seleccionar estudiante…</span>
            <i data-lucide="chevron-down" class="est-picker__chevron"></i>
          </button>
          <div class="est-picker__panel" id="estPickerMatPanel">
            <div class="est-picker__search-wrap">
              <i data-lucide="search" style="width:13px;height:13px;color:var(--gris-400);flex-shrink:0;"></i>
              <input type="text" id="estBuscadorMat" class="est-picker__search" placeholder="Buscar por nombre…" autocomplete="off" />
            </div>
            <ul class="est-picker__lista" id="estListaMat">
              <li class="est-picker__vacio">Ingresa el año para cargar estudiantes</li>
            </ul>
          </div>
        </div>
        <span class="campo__ayuda" id="ayudaEstudiante"></span>
      </div>

      <!-- Selector de grado -->
      <div class="campo">
        <label class="campo__etiqueta">Grado *</label>
        <!-- El picker visual se inyecta aquí -->
        <div id="pickerGradoMatricula"></div>
        <input type="hidden" name="gradoId" id="campoGradoMatricula" required />
        <span class="campo__ayuda" id="ayudaGrado">Solo se muestran grados del nivel correcto.</span>
      </div>

      <!-- Observaciones -->
      <div class="campo">
        <label class="campo__etiqueta">Observaciones</label>
        <textarea name="observaciones" id="campoObsMatricula" class="campo__area" rows="3"
          placeholder="Observaciones sobre el estudiante o la matrícula..."></textarea>
      </div>

      <div class="drawer__pie">
        <button type="button" class="btn btn--secundario" onclick="cerrarDrawer()">Cancelar</button>
        <button type="submit" class="btn btn--primario">
          <i data-lucide="user-check"></i> Crear matrícula
        </button>
      </div>
    </form>
  </template>

  <!-- ─── Template: Editar estado ───────────────────────────────────────── -->
  <template id="templateEditarMatricula">
    <form id="formEditarMatricula" method="POST" action="" class="formulario-grupo">
      <input type="hidden" name="_method" value="PUT" />

      <div class="campo">
        <label class="campo__etiqueta">Estado de la matrícula</label>
        <select name="estado" id="campoEstadoEditar" class="campo__select">
          <option value="activa">Activa</option>
          <option value="suspendida">Suspendida</option>
          <option value="inactiva">Inactiva</option>
          <option value="graduado">Graduado</option>
        </select>
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Cambiar grado <span style="font-weight:400;color:var(--color-texto-suave)">(solo grados con cupo disponible)</span></label>
        <select name="gradoId" id="campoGradoEditar" class="campo__select">
          <option value="">Cargando grados disponibles...</option>
        </select>
        <span class="campo__ayuda" id="ayudaGradoEditar">Solo se muestran grados del mismo nivel con cupo.</span>
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Observaciones</label>
        <textarea name="observaciones" id="campoObsEditar" class="campo__area" rows="4"
          placeholder="Observaciones sobre el estudiante o la matrícula..."></textarea>
      </div>

      <div class="drawer__pie">
        <button type="button" class="btn btn--secundario" onclick="cerrarDrawer()">Cancelar</button>
        <button type="submit" class="btn btn--primario">
          <i data-lucide="save"></i> Guardar cambios
        </button>
      </div>
    </form>
  </template>
 <!-- Datos de grados para el JS -->
      <script>
        const GRADOS_DATA_MAT = <%- JSON.stringify(grados.map(g => ({
          id:     g._id.toString(),
          _id:    g._id.toString(),
          nombre: g.nombre,
          nivel:  g.nivel,
          año:    g.año
        }))) %>;
        const FILTRO_GRADO_ACTIVO_MAT = '<%= filtroGrado %>';
        const FILTRO_ANIO_ACTIVO_MAT  = <%= filtroAnio ? filtroAnio : 'null' %>;
      </script>
  <!-- Datos del año actual para el JS -->
  <script>
    const ANO_ACTUAL = <%= añoActual %>;
  </script>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/drawer.js"></script>
  <script src="/js/paginacion.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/grado-picker.js"></script>
  <script src="/js/matriculas.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Boletines y Reportes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/paginas/boletines.css" />
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <div class="cabecera-pagina">
        <h1 class="cabecera-pagina__titulo">Boletines y Reportes</h1>
        <p class="cabecera-pagina__subtitulo">Gestión académica completa del año <%= añoSeleccionado %></p>
      </div>

      <!-- ─── Acciones de cierre (solo admin) ────────────────────────────── -->
      <% if (usuarioActual.rol === 'admin') { %>
        <div class="cierre-panel">
          <div class="cierre-panel__seccion">
            <h3 class="cierre-panel__titulo"><i data-lucide="lock"></i> Cerrar periodo</h3>
            <p class="cierre-panel__desc">Genera boletines automáticamente para todos los estudiantes del periodo.</p>
            <div class="cierre-panel__periodos">
              <% periodosAbiertos.forEach(p => { %>
                <form method="POST" action="/boletines/cerrar-periodo/<%= p._id %>?_method=PUT"
                  onsubmit="return confirm('¿Cerrar el <%= p.nombre %>? Esto generará los boletines de todos los estudiantes. Esta acción es IRREVERSIBLE.')">
                  <button type="submit" class="btn btn--secundario btn--sm">
                    <i data-lucide="lock"></i> Cerrar <%= p.nombre %>
                  </button>
                </form>
              <% }) %>
              <% if (periodosAbiertos.length === 0) { %>
                <span class="texto-secundario texto-sm">Todos los periodos están cerrados.</span>
              <% } %>
            </div>
          </div>

          <div class="cierre-panel__separador"></div>

          <div class="cierre-panel__seccion">
            <h3 class="cierre-panel__titulo"><i data-lucide="calendar-check"></i> Cerrar año académico</h3>
            <p class="cierre-panel__desc">Calcula el resultado anual y actualiza niveles. Requiere todos los periodos cerrados.</p>
            <form method="POST" action="/boletines/cerrar-anio"
              onsubmit="return confirm('¿Cerrar el año <%= añoSeleccionado %>? Se calcularán los resultados anuales y se actualizarán los niveles de los estudiantes.')">
              <input type="hidden" name="año" value="<%= añoSeleccionado %>" />
              <button type="submit" class="btn btn--primario btn--sm" <%= periodosAbiertos.length > 0 ? 'disabled title="Cierra todos los periodos primero"' : '' %>>
                <i data-lucide="calendar-check"></i> Cerrar año <%= añoSeleccionado %>
              </button>
            </form>
          </div>
        </div>
      <% } %>

      <!-- ─── Tabs de vistas ──────────────────────────────────────────────── -->
      <div class="vistas-tabs">
        <a href="/boletines/admin?año=<%= añoSeleccionado %>&vista=boletines" class="vista-tab <%= vista === 'boletines' ? 'vista-tab--activo' : '' %>">
          <i data-lucide="file-text"></i> Boletines
        </a>
        <a href="/boletines/admin?año=<%= añoSeleccionado %>&vista=reporte-grado" class="vista-tab <%= vista === 'reporte-grado' ? 'vista-tab--activo' : '' %>">
          <i data-lucide="users"></i> Reporte por grado
        </a>
        <a href="/boletines/admin?año=<%= añoSeleccionado %>&vista=reporte-materia" class="vista-tab <%= vista === 'reporte-materia' ? 'vista-tab--activo' : '' %>">
          <i data-lucide="book-open"></i> Reporte por materia
        </a>
        <a href="/boletines/admin?año=<%= añoSeleccionado %>&vista=reporte-general" class="vista-tab <%= vista === 'reporte-general' ? 'vista-tab--activo' : '' %>">
          <i data-lucide="bar-chart-2"></i> Reporte general
        </a>
      </div>

      <!-- Filtros comunes — estilo busqueda-panel igual que otras secciones -->
      <div class="busqueda-panel" style="width: 70%;">

        <!-- Tarjeta lateral izquierda -->
        <div class="acceso-card acceso-card--azul" style="min-height:130px; min-width:130px;">
          <div class="tarjeta-stat__icono tarjeta-stat__icono--azul">
            <i data-lucide="file-badge"></i>
          </div>
          <div class="tarjeta-stat__datos" style="text-align:center;">
            <span class="tarjeta-stat__etiqueta" style="font-size:0.75rem;color:var(--azul-700);font-weight:600;line-height:1.3;">Consulta boletines<br>y reportes de<br><strong><%= añoSeleccionado %></strong></span>
          </div>
        </div>

        <!-- Barra de filtros derecha -->
        <form method="GET" action="/boletines/admin" class="busqueda-panel__barra busqueda-panel__barra--azul" id="formFiltros" style="flex-direction:column; align-items:stretch; gap:10px;">
          <input type="hidden" name="vista" value="<%= vista %>" />
          <input type="hidden" name="gradoId" id="inputFiltroGradoBol" value="<%= gradoIdActivo %>" />

          <!-- Fila superior: año + periodo + limpiar -->
          <div class="barra-filtros__fila-superior" style="padding:0; flex-wrap:wrap; gap:10px;">

            <!-- Año -->
            <div class="barra-filtros__anio-wrap" style="display:flex;align-items:center;gap:6px;">
              <i data-lucide="calendar" class="barra-filtros__anio-icono"></i>
              <span class="barra-filtros__anio-label">Año</span>
              <select name="año" class="barra-filtros__anio-select" id="selectAnioBol" onchange="this.form.submit()">
                <% añosDisponibles.forEach(a => { %>
                  <option value="<%= a %>" <%= añoSeleccionado === a ? 'selected' : '' %>><%= a %></option>
                <% }) %>
              </select>
            </div>

            <!-- Periodo -->
            <div class="barra-filtros__anio-wrap">
              <select name="periodoId" class="barra-filtros__anio-select" onchange="this.form.submit()">
                <option value="">Todos los periodos</option>
                <% periodos.forEach(p => { %>
                  <option value="<%= p._id %>" <%= periodoIdActivo === p._id.toString() ? 'selected' : '' %>><%= p.nombre %> <%= !p.activo ? '' : '(Abierto)' %></option>
                <% }) %>
              </select>
            </div>

            <!-- Materia (solo vista reporte-materia) — dropdown dinámico con búsqueda -->
            <% if (vista === 'reporte-materia' && materiasGrado.length > 0) { %>
              <input type="hidden" name="materiaId" id="inputMateriaIdBol" value="<%= materiaIdActiva %>" />
              <div class="materia-picker-wrap" id="materiaPickerBol">
                <button type="button" class="materia-picker__trigger" id="materiaPickerTriggerBol">
                  <i data-lucide="book-open" style="width:14px;height:14px;flex-shrink:0;"></i>
                  <span id="materiaPickerLabelBol">
                    <% if (materiaIdActiva) {
                         const mSel = materiasGrado.find(m => m._id.toString() === materiaIdActiva);
                         if (mSel) { %><%= mSel.nombre %><% } else { %>Seleccionar materia<% } %>
                    <% } else { %>Seleccionar materia<% } %>
                  </span>
                  <i data-lucide="chevron-down" class="materia-picker__chevron" style="width:13px;height:13px;margin-left:auto;"></i>
                </button>
                <div class="materia-picker__panel" id="materiaPickerPanelBol">
                  <div class="materia-picker__search-wrap">
                    <i data-lucide="search" style="width:13px;height:13px;color:var(--gris-500);flex-shrink:0;"></i>
                    <input type="text" id="materiaBuscadorBol" class="materia-picker__search" placeholder="Buscar materia…" autocomplete="off" />
                  </div>
                  <ul class="materia-picker__lista" id="materiaListaBol">
                    <li class="materia-picker__opcion" data-id="" data-nombre="Todas las materias">
                      <i data-lucide="list" style="width:13px;height:13px;flex-shrink:0;"></i>
                      Todas las materias
                    </li>
                    <% materiasGrado.forEach(m => { %>
                      <li class="materia-picker__opcion <%= materiaIdActiva === m._id.toString() ? 'materia-picker__opcion--activa' : '' %>"
                          data-id="<%= m._id %>" data-nombre="<%= m.nombre %>">
                        <i data-lucide="book" style="width:13px;height:13px;flex-shrink:0;"></i>
                        <%= m.nombre %>
                      </li>
                    <% }) %>
                  </ul>
                </div>
              </div>
            <% } %>

            <!-- Botón limpiar -->
            <% if (gradoIdActivo || periodoIdActivo) { %>
              <a href="/boletines/admin?año=<%= añoSeleccionado %>&vista=<%= vista %>" class="btn btn--secundario btn--sm">
                <i data-lucide="x"></i> Limpiar
              </a>
            <% } %>
          </div>

          <!-- Fila inferior: picker de grado (ancho controlado) -->
          <div style="width: 100%;">
            <div class="filtro-nivel-wrap">
              <button type="button" class="filtro-nivel_edu" id="btnFiltroGradoBol">
                <i data-lucide="book-open"></i>
                <span>Grado</span>
                <% if (gradoIdActivo) {
                     const gradoSel = grados.find(g => g._id.toString() === gradoIdActivo);
                     if (gradoSel) { %>
                  <span class="filtro-nivel__badge-trigger"><%= gradoSel.nombre %></span>
                <% }} %>
                <i data-lucide="chevron-down" class="filtro-nivel__chevron"></i>
              </button>
              <div class="filtro-nivel__panel" id="panelFiltroGradoBol"></div>
            </div>
          </div>

        </form>
      </div>

      <!-- ─── CONTENIDO POR VISTA ──────────────────────────────────────── -->

      <!-- VISTA: Boletines -->
      <% if (vista === 'boletines') { %>

        <% if (boletines.length === 0) { %>
          <div class="estado-vacio">
            <i data-lucide="file-text"></i>
            <h3>Sin boletines</h3>
            <p>Selecciona grado y periodo para ver boletines, o cierra un periodo para generarlos.</p>
          </div>
        <% } else { %>
          <!-- Botón de descarga de todos -->
          <% if (gradoIdActivo && periodoIdActivo) { %>
            <div style="display:flex;gap:8px;margin-bottom:8px;">
              <a href="/boletines/reporte/grado/pdf?gradoId=<%= gradoIdActivo %>&periodoId=<%= periodoIdActivo %>&año=<%= añoSeleccionado %>"
                target="_blank" class="btn btn--secundario" style="padding:8px 20px;font-size:0.9rem;">
                <i data-lucide="download"></i> PDF reporte del grado
              </a>
            </div>
          <% } %>

          <div class="tabla-contenedor tabla-contenedor--scroll">
            <table class="tabla">
              <thead>
                <tr>
                  <th>Estudiante</th>
                  <th>Grado</th>
                  <th>Periodo</th>
                  <th>Año</th>
                  <th>Promedio</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="tbodyBoletines">
                <% boletines.forEach(b => { %>
                  <tr>
                    <td><strong><%= b.nombreEstudiante %> <%= b.apellidoEstudiante %></strong></td>
                    <td class="texto-secundario"><%= b.nombreGrado %></td>
                    <td class="texto-secundario"><%= b.nombrePeriodo %></td>
                    <td class="texto-secundario"><%= b.año %></td>
                    <td>
                      <span class="nota-boletin nota-boletin--<%= b.aprobadoGeneral ? 'ok' : 'mal' %>">
                        <%= b.promedioGeneral.toFixed(2) %>
                      </span>
                    </td>
                    <td>
                      <span class="badge <%= b.aprobadoGeneral ? 'badge--activo' : 'badge--error' %>">
                        <%= b.aprobadoGeneral ? 'Aprobado' : 'Reprobado' %>
                      </span>
                    </td>
                    <td>
                      <div class="acciones-tabla">
                        <a href="/boletines/admin?año=<%= b.año %>&vista=boletines&gradoId=<%= b.gradoId %>&periodoId=<%= b.periodoId %>&estudianteId=<%= b.estudianteId %>"
                          class="btn-icono btn-icono--ver" title="Ver boletín">
                          <i data-lucide="eye"></i>
                        </a>
                        <a href="/boletines/admin/<%= b._id %>/pdf" target="_blank"
                          class="btn-icono btn-icono--editar" title="Descargar PDF">
                          <i data-lucide="download"></i>
                        </a>
                        <form method="POST" action="/boletines/admin/<%= b._id %>?_method=DELETE"
                          onsubmit="return confirm('¿Eliminar el boletín de <%= b.nombreEstudiante %>?')" style="display:inline">
                          <button type="submit" class="btn-icono btn-icono--eliminar" title="Eliminar">
                            <i data-lucide="trash-2"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Ver boletín individual si hay estudianteId -->
          <% if (estudianteIdActivo && boletines.length === 1) { %>
            <div style="margin-top:16px;">
              <%- include('../partials/boletin-card', { b: boletines[0], mostrarEliminar: true, rol: 'admin' }) %>
            </div>
          <% } %>
        <% } %>

      <!-- VISTA: Reporte por grado -->
      <% } else if (vista === 'reporte-grado') { %>
        <%- include('../partials/reporte-grado', { reporte }) %>

      <!-- VISTA: Reporte por materia -->
      <% } else if (vista === 'reporte-materia') { %>
        <%- include('../partials/reporte-materia', { reporte, gradoIdActivo, periodoIdActivo, materiaIdActiva, añoSeleccionado }) %>

      <!-- VISTA: Reporte general -->
      <% } else if (vista === 'reporte-general') { %>
        <%- include('../partials/reporte-general', { reporte, añoSeleccionado, periodoIdActivo }) %>
      <% } %>

    </main>
  </div>

    <!-- Datos de grados para el picker -->
    <script>
      const GRADOS_DATA_BOL = <%- JSON.stringify(grados.map(g => ({
        id:     g._id.toString(),
        _id:    g._id.toString(),
        nombre: g.nombre,
        nivel:  g.nivel,
        año:    g.año
      }))) %>;
      const FILTRO_GRADO_ACTIVO_BOL = '<%= gradoIdActivo || "" %>';
    </script>

  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/paginacion.js"></script>
  <script src="/js/grado-picker.js"></script>
  <script src="/js/boletines.js"></script>
  <script>
  document.addEventListener('DOMContentLoaded', function () {
    initFiltroGradoPicker({
      gradosData:        GRADOS_DATA_BOL,
      filtroGradoActivo: FILTRO_GRADO_ACTIVO_BOL,
      formId:            'formFiltros',
      inputHiddenId:     'inputFiltroGradoBol',
      anioSelectName:    'año',
      triggerBtnId:      'btnFiltroGradoBol',
      panelId:           'panelFiltroGradoBol',
    });
  });
  </script>
  <script>lucide.createIcons();</script>
</body>
</html>

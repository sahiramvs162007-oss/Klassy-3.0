<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Materias</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/componentes/busqueda-panel.css">

  
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash messages -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <!-- Cabecera -->
      <div class="cabecera-pagina">
        <div>
          <h1 class="cabecera-pagina__titulo">Gestión de Materias</h1>
        </div>
        <div class="cabecera-pagina__acciones">
          <button class="btn btn--primario" onclick="abrirDrawerCrearMateria()">
            <i data-lucide="plus"></i> Nueva materia
          </button>
        </div>
      </div>

      <!-- Panel de búsqueda -->
      <div class="busqueda-panel">
        <!-- Stat card -->
        <div class="acceso-card acceso-card--morado"><div class="tarjeta-stat__icono tarjeta-stat__icono--morado"><i data-lucide="book-open"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= materias.length %></span><span class="tarjeta-stat__etiqueta">Materias</span></div></div>

        <!-- Barra de búsqueda -->
        <form method="GET" action="/materias" class="busqueda-panel__barra busqueda-panel__barra--morado" >
          <div class="busqueda-panel__campo">
            <i data-lucide="search" class="busqueda-panel__icono-buscar"></i>
            <input
              type="text"
              name="buscar"
              value="<%= buscar %>"
              placeholder="Buscar materia por nombre..."
              class="busqueda-panel__entrada"
            />
          </div>
          <div class="busqueda-panel__acciones">
            <button type="submit" class="btn btn--primario btn--sm">
              <i data-lucide="search"></i> Buscar
            </button>
            <% if (buscar) { %>
              <a href="/materias" class="btn btn--secundario btn--sm">
                <i data-lucide="x"></i> Limpiar
              </a>
            <% } %>
          </div>
        </form>
      </div>

      <!-- Tabla -->
      <div class="tabla-contenedor tabla-container">
        <% if (materias.length === 0) { %>
          <div class="tabla-vacia">
            <i data-lucide="book-open"></i>
            <p>No hay materias registradas aún.</p>
          </div>
        <% } else { %>
          <table class="tabla">
            <thead>
              <tr>
                <th>Materia</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbodyMaterias">
              <% materias.forEach(m => { %>
                <tr>
                  <td>
                    <div class="item-icono">
                      <div class="item-icono__circulo item-icono__circulo--azul">
                        <i data-lucide="book-open"></i>
                      </div>
                      <span class="item-icono__texto"><%= m.nombre %></span>
                    </div>
                  </td>
                  <td class="texto-secundario texto-sm" style="text-align: left;">
                    <%= m.descripcion ? m.descripcion : 'Sin descripción' %>
                  </td>
                  <td>
                    <span class="badge <%= m.activo ? 'badge--activo' : 'badge--inactivo' %>">
                      <%= m.activo ? 'Activa' : 'Inactiva' %>
                    </span>
                  </td>
                  <td>
                    <div class="acciones-tabla" >
                      <button class="btn-icono btn-icono--editar" onclick="abrirDrawerEditarMateria('<%= m._id %>')" title="Editar">
                        <i data-lucide="pencil"></i>
                      </button>
                      <form method="POST" action="/materias/<%= m._id %>?_method=DELETE"
                        onsubmit="return confirmarEliminar('<%= m.nombre %>')" style="display:inline">
                        <button type="submit" class="btn-icono btn-icono--eliminar" title="Eliminar">
                          <i data-lucide="trash-2"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            
          </table>
        <% } %>
      </div>

    </main>
  </div>

  <!-- Drawer -->
  <div class="drawer-overlay" id="drawerOverlay" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo" id="drawerTitulo">Nueva materia</h2>
      <button class="drawer__cerrar" onclick="cerrarDrawer()"><i data-lucide="x"></i></button>
    </div>
    <div class="drawer__cuerpo" id="drawerCuerpo"></div>
  </div>

  <!-- Template formulario materia -->
  <template id="templateFormMateria">
    <form id="formMateria" method="POST" action="/materias" class="formulario-grupo">
      <input type="hidden" name="_method" id="metodoMateria" value="" />

      <div class="campo">
        <label class="campo__etiqueta">Nombre de la materia *</label>
        <input type="text" name="nombre" id="campoNombreMateria" class="campo__entrada" required placeholder="Ej: Matemáticas, Ciencias Naturales" />
      </div>

      <div class="campo">
        <label class="campo__etiqueta">Descripción</label>
        <textarea name="descripcion" id="campoDescMateria" class="campo__area" rows="4" placeholder="Describe brevemente de qué trata esta materia..."></textarea>
      </div>

      <div class="campo" id="grupoActivoMateria" style="display:none;">
        <label class="campo__etiqueta">Estado</label>
        <select name="activo" id="campoActivoMateria" class="campo__select">
          <option value="true">Activa</option>
          <option value="false">Inactiva</option>
        </select>
      </div>

      <div class="drawer__pie">
        <button type="button" class="btn btn--secundario" onclick="cerrarDrawer()">Cancelar</button>
        <button type="submit" class="btn btn--primario">
          <i data-lucide="save"></i>
          <span id="textoGuardarMateria">Crear materia</span>
        </button>
      </div>
    </form>
  </template>
  
  <script src="/js/notificaciones.js"></script>
  <script src="/js/drawer.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/paginacion.js"></script>
  <script src="/js/materias.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>

<%
  // Simula el include del layout principal
  // En cada vista hacemos include manual del layout
%>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>

    <main class="contenido">

      <!-- Flash messages -->
      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito">
          <i data-lucide="check-circle"></i>
          <span><%= mensajeExito %></span>
        </div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error">
          <i data-lucide="alert-circle"></i>
          <span><%= mensajeError %></span>
        </div>
      <% } %>

      <!-- Cabecera del dashboard -->
      <div class="cabecera-pagina">
        <div>
          <h1 class="cabecera-pagina__titulo">Bienvenido a KLASSY</h1>
          <p class="cabecera-pagina__subtitulo">Panel de gestión académica</p>
        </div>
      </div>

      <!-- Tarjetas de resumen (placeholders para sprints futuros) -->
      <div class="cuadricula-tarjetas">

        <div class="tarjeta-stat">
          <div class="tarjeta-stat__icono tarjeta-stat__icono--azul">
            <i data-lucide="users"></i>
          </div>
          <div class="tarjeta-stat__datos">
            <span class="tarjeta-stat__valor">—</span>
            <span class="tarjeta-stat__etiqueta">Estudiantes</span>
          </div>
        </div>

        <div class="tarjeta-stat">
          <div class="tarjeta-stat__icono tarjeta-stat__icono--verde">
            <i data-lucide="graduation-cap"></i>
          </div>
          <div class="tarjeta-stat__datos">
            <span class="tarjeta-stat__valor">—</span>
            <span class="tarjeta-stat__etiqueta">Grados activos</span>
          </div>
        </div>

        <div class="tarjeta-stat">
          <div class="tarjeta-stat__icono tarjeta-stat__icono--naranja">
            <i data-lucide="book-open"></i>
          </div>
          <div class="tarjeta-stat__datos">
            <span class="tarjeta-stat__valor">—</span>
            <span class="tarjeta-stat__etiqueta">Materias</span>
          </div>
        </div>

        <div class="tarjeta-stat">
          <div class="tarjeta-stat__icono tarjeta-stat__icono--morado">
            <i data-lucide="clipboard-list"></i>
          </div>
          <div class="tarjeta-stat__datos">
            <span class="tarjeta-stat__valor">—</span>
            <span class="tarjeta-stat__etiqueta">Actividades</span>
          </div>
        </div>

      </div>

      <!-- Bloque visión y misión del colegio (placeholder) -->
      <div class="cuadricula-2col">

        <div class="tarjeta">
          <div class="tarjeta__cabecera">
            <i data-lucide="eye"></i>
            <h3 class="tarjeta__titulo">Visión</h3>
          </div>
          <p class="tarjeta__texto tarjeta__texto--placeholder">
            La visión del colegio se configurará en el módulo de ajustes institucionales.
          </p>
        </div>

        <div class="tarjeta">
          <div class="tarjeta__cabecera">
            <i data-lucide="target"></i>
            <h3 class="tarjeta__titulo">Misión</h3>
          </div>
          <p class="tarjeta__texto tarjeta__texto--placeholder">
            La misión del colegio se configurará en el módulo de ajustes institucionales.
          </p>
        </div>

      </div>

      <!-- Noticias recientes (placeholder para Sprint 12) -->
      <div class="tarjeta tarjeta--completo">
        <div class="tarjeta__cabecera">
          <i data-lucide="newspaper"></i>
          <h3 class="tarjeta__titulo">Noticias recientes</h3>
        </div>
        <p class="tarjeta__texto tarjeta__texto--placeholder">
          Las noticias del colegio estarán disponibles en el Sprint 12.
        </p>
      </div>

    </main>
  </div>

  <!-- Drawer lateral -->
  <div class="drawer-overlay" id="drawerOverlay" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo" id="drawerTitulo">Detalle</h2>
      <button class="drawer__cerrar" onclick="cerrarDrawer()">
        <i data-lucide="x"></i>
      </button>
    </div>
    <div class="drawer__cuerpo" id="drawerCuerpo"></div>
  </div>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/drawer.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>

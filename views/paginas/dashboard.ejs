<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KLASSY — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Fraunces:ital,wght@0,700;1,400&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/estilos.css" />
  <link rel="stylesheet" href="/css/paginas/dashboard.css" />
  <link rel="stylesheet" href="/css/main.css">

  
</head>
<body>
  <%- include('../partials/sidebar') %>
  <div class="contenedor-principal">
    <%- include('../partials/topbar') %>
    <main class="contenido">

      <% if (mensajeExito && mensajeExito.length > 0) { %>
        <div class="alerta alerta--exito"><i data-lucide="check-circle"></i><span><%= mensajeExito %></span></div>
      <% } %>
      <% if (mensajeError && mensajeError.length > 0) { %>
        <div class="alerta alerta--error"><i data-lucide="alert-circle"></i><span><%= mensajeError %></span></div>
      <% } %>

      <% if (rol === 'admin') { %>
        <%# ═══════════ ADMIN ═══════════ %>

        <%# ── 1. HERO: bienvenida + acciones ── %>
        <div class="hero-admin">

          <%# Bienvenida %>
          <div class="hero-admin__bienvenida">
            <h1 class="hero-admin__titulo titu1">
              Bienvenido, <em><%= usuarioActual.nombre %></em> 
            </h1>
            <p class="hero-admin__sub">Gestiona tu institución desde un solo lugar.</p>
            <div class="hero-admin__acciones">
              <a href="/noticias" class="btn-hero btn-hero--secundario"><i data-lucide="newspaper"></i> Noticias</a>
              <a href="/historial" class="btn-hero btn-hero--secundario" style="background:#4f46e5;color:#fff;border-color:#4f46e5;"><i data-lucide="clock"></i> Historial de cambios</a>
              <button class="btn-hero btn-hero--primario" onclick="abrirDrawerConfig()"><i data-lucide="settings-2"></i> Configuración</button>
            </div>
          </div>

          <%# Imágenes de estudiantes — siempre visibles %>
          <div class="hero-admin__ilustracion">
            <div class="est-1">
              <img src="imagenes/chico_secundaria.png" alt="Estudiante" class="est-hero" />
            </div>
            <div class="est-2">
              <img src="imagenes/chica_est.png" alt="Estudiante" class="est-hero" />
            </div>
          </div>

          <%# ── Stats ── %>
          <section class="acceso-rapido-seccion">
            <div class="acceso-rapido-seccion">
              <div class="acceso-card acceso-card--azul"><div class="tarjeta-stat__icono tarjeta-stat__icono--azul"><i data-lucide="users"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= stats.totalEstudiantes %></span><span class="tarjeta-stat__etiqueta">Estudiantes</span></div></div>
              <div class="acceso-card acceso-card--verde"><div class="tarjeta-stat__icono tarjeta-stat__icono--verde"><i data-lucide="user-check"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= stats.totalDocentes %></span><span class="tarjeta-stat__etiqueta">Docentes</span></div></div>
              <div class="acceso-card acceso-card--naranja"><div class="tarjeta-stat__icono tarjeta-stat__icono--naranja"><i data-lucide="graduation-cap"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= stats.totalGrados %></span><span class="tarjeta-stat__etiqueta">Grados activos</span></div></div>
              <div class="acceso-card acceso-card--morado"><div class="tarjeta-stat__icono tarjeta-stat__icono--morado"><i data-lucide="book-open"></i></div><div class="tarjeta-stat__datos"><span class="tarjeta-stat__valor"><%= stats.totalMaterias %></span><span class="tarjeta-stat__etiqueta">Materias</span></div></div>
            </div>
          </section>

          <%# ── INFO COLEGIO: visión/misión ── %>
          <section id="infocolegio">
            <div class="infocolegio__brillo"></div>
            <div class="infocolegio__contenido">
              <div class="infocolegio__encabezado">
                <h2 class="infocolegio__titulo">Información Institucional</h2>
                <span class="infocolegio__chip"><i data-lucide="building-2"></i> <%= (config&&config.nombreColegio) ? config.nombreColegio : 'KLASSY' %></span>
              </div>
              <div class="infocolegio__presentacion">
                <h2 class="infocolegio__nombre-grande"><%= config && config.nombreColegio ? config.nombreColegio : 'Nombre del colegio' %></h2>
                <div class="infocolegio__contenido-flex">
                  <div class="infocolegio__logo">
                    <% if(config && config.logo){ %>
                      <img src="/uploads/<%= config.logo %>" alt="Logo colegio">
                    <% } %>
                  </div>
                </div>
              </div>
              <div class="cuadricula-2col">
                <div class="tarjeta tarjeta--vision" id="tarjetaVision">
                  <div class="tarjeta__cabecera"><i data-lucide="eye"></i><h3 class="tarjeta__titulo">Visión</h3></div>
                  <p class="tarjeta__texto"><% if(config&&config.vision){%><%= config.vision %><%}else{%><em class="texto-vacio">Sin configurar.</em><%}%></p>
                  <button class="tarjeta__btn-ver-mas" id="btnVisionMas" onclick="toggleTarjeta('tarjetaVision','btnVisionMas')" style="display:none;">Ver más <i data-lucide="chevron-down"></i></button>
                </div>
                <div class="tarjeta tarjeta--mision" id="tarjetaMision">
                  <div class="tarjeta__cabecera"><i data-lucide="target"></i><h3 class="tarjeta__titulo">Misión</h3></div>
                  <p class="tarjeta__texto"><% if(config&&config.mision){%><%= config.mision %><%}else{%><em class="texto-vacio">Sin configurar.</em><%}%></p>
                  <button class="tarjeta__btn-ver-mas" id="btnMisionMas" onclick="toggleTarjeta('tarjetaMision','btnMisionMas')" style="display:none;">Ver más <i data-lucide="chevron-down"></i></button>
                </div>
              </div>
            </div>
          </section>

          <%# ── NOTICIAS ── %>
          <% if(noticias&&noticias.length>0){%>
            <section class="noticias-admin-seccion">
              <div class="seccion-titulo"><i data-lucide="newspaper"></i> Noticias publicadas <span class="seccion-conteo"><%= noticias.length %></span></div>
              <div class="mosaico-mini">
                <%noticias.slice(0,4).forEach(n=>{%>
                  <div class="noticia-mini noticia-clickable"
                    data-titulo="<%= n.titulo %>"
                    data-etiqueta="<%= n.etiqueta || 'Anuncios' %>"  
                    data-fecha="<%= n.fechaPublicacion %>"
                    data-autor="<%= n.autorId ? n.autorId.nombre+' '+n.autorId.apellido : '' %>"
                    data-imagen="<%= n.imagen || '' %>">
                    <%if(n.imagen){%><img src="<%= n.imagen %>" alt="<%= n.titulo %>" class="noticia-mini__img"/><%}else{%><div class="noticia-mini__sin-img"><i data-lucide="image"></i></div><%}%>
                    <div class="noticia-mini__info">
                      <span class="noticia-mini__titulo"><%= n.titulo %></span>
                      <span class="noticia-mini__fecha"><%= new Date(n.fechaPublicacion).toLocaleDateString('es-CO',{day:'2-digit',month:'short'}) %></span>
                    </div>
                    <span class="noticia-contenido-oculto" style="display:none"><%= n.contenido %></span>
                  </div>
                <%})%>
              </div>
            </section>
          <%}%>

        </div><%# /hero-admin %>

      <% } else { %>
        <%# ═══════════ DOCENTE / ESTUDIANTE ═══════════ %>
        <section class="content_do_est">

          <%# ── 1. HERO colegio ── %>
          <div class="hero-colegio" style="background-image: url('<% if(config && config.fotoInstitucion){ %>/uploads/<%= config.fotoInstitucion %><% } else { %>imagenes/fondo_colegio_default.png<% } %>'); background-size: cover; background-position: center;">
            <div class="hero-colegio__overlay">
              <div class="hero-colegio__info">
                <h1 class="hero-colegio__nombre"><%= (config&&config.nombreColegio) ? config.nombreColegio : 'KLASSY' %></h1>
                <p class="hero-colegio__saludo">
                  Bienvenido, <em><%= usuarioActual.nombre %> <%= usuarioActual.apellido %></em>
                </p>
                <span class="hero-colegio__badge"><%= rol.charAt(0).toUpperCase()+rol.slice(1) %></span>
              </div>
            </div>
          </div>

          <%# ── 2. SECCIÓN MISIÓN/VISIÓN + ILUSTRACIÓN (siempre visible) ── %>
          <div class="mv-seccion">
            
            <%# Tarjetas misión y visión (se expanden inline) %>
            <div class="mv-tarjetas">
              <h2 class="hero-admin__titulo titu2">Nuestra identidad</h2>

              <%# Tarjeta MISIÓN %>
              <div class="mv-card mv-card--mision mv-expandible" data-tipo="mision">
                <div class="brillo"></div>
                <div class="mv-card__icono mv-card__icono--mision">
                  <i data-lucide="target"></i>
                </div>
                <div class="mv-card__datos">
                  <span class="mv-card__etiqueta">Misión</span>
                  <% if(config&&config.mision){ %>
                    <span class="mv-card__valor">Ver misión</span>
                  <% } else { %>
                    <span class="mv-card__valor mv-card__valor--vacio">Sin configurar</span>
                  <% } %>
                </div>
                <i data-lucide="chevron-down" class="mv-card__flecha"></i>
                <div class="mv-inline-panel" id="panelMision"><div>
                  <% if(config&&config.mision){ %>
                    <p class="mv-inline-panel__texto"><%= config.mision %></p>
                  <% } else { %>
                    <p class="mv-inline-panel__texto mv-card__valor--vacio"><i data-lucide="info" style="width:14px;height:14px;vertical-align:middle;margin-right:5px;"></i>La misión institucional aún no ha sido configurada.</p>
                  <% } %>
                </div></div>
              </div>

              <%# Tarjeta VISIÓN %>
              <div class="mv-card mv-card--vision mv-expandible" data-tipo="vision">
                <div class="mv-card__icono mv-card__icono--vision">
                  <i data-lucide="eye"></i>
                </div>
                <div class="mv-card__datos">
                  <span class="mv-card__etiqueta">Visión</span>
                  <% if(config&&config.vision){ %>
                    <span class="mv-card__valor">Ver visión</span>
                  <% } else { %>
                    <span class="mv-card__valor mv-card__valor--vacio">Sin configurar</span>
                  <% } %>
                </div>
                <i data-lucide="chevron-down" class="mv-card__flecha"></i>
                <div class="mv-inline-panel" id="panelVision"><div>
                  <% if(config&&config.vision){ %>
                    <p class="mv-inline-panel__texto"><%= config.vision %></p>
                  <% } else { %>
                    <p class="mv-inline-panel__texto mv-card__valor--vacio"><i data-lucide="info" style="width:14px;height:14px;vertical-align:middle;margin-right:5px;"></i>La visión institucional aún no ha sido configurada.</p>
                  <% } %>
                </div></div>
              </div>
            </div>

            <%# Ilustración estudiantes — siempre visible %>
            <div class="mv-ilustracion">
              <div class="est-1">
                <img src="imagenes/chico_secundaria.png" alt="Estudiante" class="est-hero" />
              </div>
              <div class="est-2">
                <img src="imagenes/chica_est.png" alt="Estudiante" class="est-hero" />
              </div>
            </div>

          </div>

          <%# ── 3. NOTICIAS ── %>
          <div class="noticias-seccion">
            <%# Título siempre visible %>
            <div class="noticias-seccion__titulo">
              <i data-lucide="newspaper"></i>
              <span>Noticias del colegio</span>
              <% if(noticias && noticias.length > 0) { %>
                <span class="seccion-conteo"><%= noticias.length %> publicación<%= noticias.length!==1?'es':'' %></span>
              <% } %>
            </div>

            <% if(noticias && noticias.length > 0) { %>
              <%# ── CAMBIO: el loop ya no calcula posiciones; el JS lo hace todo ── %>
              <div class="mosaico-noticias-3col <%= noticias.length >= 4 ? 'mosaico-activo-3col' : 'lista-simple-3col' %>">
                <% noticias.forEach(function(n) { %>
                <article class="noticia-card noticia-clickable"
                         data-titulo="<%= n.titulo %>"
                         data-fecha="<%= n.fechaPublicacion %>"
                         data-autor="<%= n.autorId ? n.autorId.nombre+' '+n.autorId.apellido : '' %>"
                         data-imagen="<%= n.imagen || '' %>"
                         data-etiqueta="<%= n.etiqueta %>">
                  <% if(n.imagen){ %>
                    <div class="noticia-card__foto">
                      <img src="<%= n.imagen %>" alt="<%= n.titulo %>" class="noticia-card__foto-img" loading="lazy"/>
                    </div>
                  <% } else { %>
                    <div class="noticia-card__foto noticia-card__foto--vacia"><i data-lucide="image"></i></div>
                  <% } %>
                  <div class="noticia-card__cuerpo">
                    <span class="noticia-etiqueta noticia-etiqueta--<%= (n.etiqueta||'Anuncios').toLowerCase().replace(/ /g,'-').replace(/[^a-z0-9-]/g,'') %>">
                      <%= n.etiqueta || 'Anuncios' %>
                    </span>
                    <time class="noticia-card__fecha"><%= new Date(n.fechaPublicacion).toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'}) %></time>
                    <h3 class="noticia-card__titulo"><%= n.titulo %></h3>
                    <p class="noticia-card__texto">
                      <%= n.contenido ? (n.contenido.length > 110 ? n.contenido.substring(0,110) + '…' : n.contenido) : 'Sin descripción' %>
                    </p>
                    <div class="noticia-card__pie">
                      <i data-lucide="user"></i>
                      <span><%= n.autorId ? n.autorId.nombre+' '+n.autorId.apellido : '' %></span>
                      <span class="noticia-card__leer-mas">Ver más <i data-lucide="arrow-right"></i></span>
                    </div>
                  </div>
                  <span class="noticia-contenido-oculto" style="display:none"><%= n.contenido %></span>
                </article>
                <% }); %>
              </div>
            <% } else { %>
              <%# Estado vacío — igual al apartado de gestión de noticias %>
              <div class="estado-vacio estado-vacio--noticias">
                <div class="estado-vacio__icono">
                  <i data-lucide="newspaper"></i>
                </div>
                <h3 class="estado-vacio__titulo">Sin noticias</h3>
                <p class="estado-vacio__desc">Crea la primera noticia para que aparezca en el dashboard del colegio.</p>
              </div>
            <% } %>
          </div>

        </section>
      <% } %>

    </main>
  </div>

  <%# ─── Drawer de noticia ── %>
  <div class="drawer-overlay" id="drawerOverlay" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo" id="drawerTitulo">Noticia</h2>
      <button class="drawer__cerrar" onclick="cerrarDrawer()"><i data-lucide="x"></i></button>
    </div>
    <div class="drawer__cuerpo" id="drawerCuerpo"></div>
  </div>

  <%# ─── Drawer de configuración (solo admin) ── %>
  <%if(rol==='admin'){%>
  <div class="drawer-overlay" id="configOverlay" onclick="cerrarConfig()" style="z-index:199;display:none;"></div>
  <div class="drawer" id="drawerConfig" style="z-index:200;">
    <div class="drawer__cabecera">
      <h2 class="drawer__titulo">Configuración institucional</h2>
      <button class="drawer__cerrar" onclick="cerrarConfig()"><i data-lucide="x"></i></button>
    </div>
    <div class="drawer__cuerpo">
      <form method="POST" action="/dashboard/configuracion?_method=PUT" enctype="multipart/form-data">
        <div class="campo"><label class="campo__etiqueta">Nombre del colegio</label><input type="text" name="nombreColegio" class="campo__entrada" value="<%= config&&config.nombreColegio?config.nombreColegio:'' %>" placeholder="Nombre oficial" /></div>
        <div class="campo"><label class="campo__etiqueta">Visión institucional</label><textarea name="vision" class="campo__area" rows="4" placeholder="Visión del colegio..."><%= config&&config.vision?config.vision:'' %></textarea></div>
        <div class="campo"><label class="campo__etiqueta">Misión institucional</label><textarea name="mision" class="campo__area" rows="4" placeholder="Misión del colegio..."><%= config&&config.mision?config.mision:'' %></textarea></div>
        <div class="campo"><label class="campo__etiqueta">Correo del director</label><input type="email" name="correoDirector" class="campo__entrada" value="<%= config&&config.correoDirector?config.correoDirector:'' %>" placeholder="director@colegio.edu.co" /></div>
        <div class="campo">
          <label class="campo__etiqueta">Foto de la institución</label>
          <label for="inputFotoInstitucion" class="zona-upload">
            <i data-lucide="image"></i>
            <span>Haz clic para seleccionar una imagen</span>
            <span class="zona-upload__tipos">JPG · PNG · WebP · GIF (máx 10 MB)</span>
          </label>
          <input type="file" id="inputFotoInstitucion" name="fotoInstitucion"
            accept="image/*"
            onchange="previsualizarFotoInst(this)"
            style="display:none" />
          <div id="previewFotoInst" style="margin-top:8px;"></div>
        </div>
        <div class="drawer__pie">
          <button type="button" class="btn btn--secundario" onclick="cerrarConfig()">Cancelar</button>
          <button type="submit" class="btn btn--primario"><i data-lucide="save"></i> Guardar</button>
        </div>
      </form>
    </div>
  </div>
  <%}%>

  
  <script src="/js/drawer.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/notificaciones.js"></script>
  <script src="/js/dashboard.js"></script>
  <script>
    /* ── "Ver más / Ver menos" en tarjetas visión y misión — solo móvil ── */
    function toggleTarjeta(tarjetaId, btnId) {
      var tarjeta = document.getElementById(tarjetaId);
      var btn = document.getElementById(btnId);
      if (!tarjeta || !btn) return;
      var expandida = tarjeta.classList.toggle('tarjeta--expandida');
      btn.innerHTML = expandida
        ? 'Ver menos <i data-lucide="chevron-up"></i>'
        : 'Ver más <i data-lucide="chevron-down"></i>';
      lucide.createIcons();
    }

    function iniciarVerMas() {
      if (window.innerWidth > 768) return;
      [
        { sel: '.tarjeta--vision .tarjeta__texto', btn: 'btnVisionMas' },
        { sel: '.tarjeta--mision .tarjeta__texto', btn: 'btnMisionMas' },
      ].forEach(function(item) {
        var p = document.querySelector(item.sel);
        var b = document.getElementById(item.btn);
        if (!p || !b) return;
        var lineH = parseFloat(getComputedStyle(p).lineHeight) || 22;
        if (p.scrollHeight > lineH * 3 + 6) {
          b.style.display = 'inline-flex';
          lucide.createIcons();
        }
      });
    }

    document.addEventListener('DOMContentLoaded', iniciarVerMas);
  </script>
</body>
</html>
